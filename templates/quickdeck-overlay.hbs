<div class="qd40-frame">
  <div class="qd40-chrome-row" data-action="drag-overlay" title="Drag QuickDeck">
    <div class="qd40-corner-badge">
      <span class="qd40-corner-title">GURPS QuickDeck</span>
      <button
        type="button"
        class="qd40-info-button"
        data-action="toggle-info-popover"
        aria-expanded="{{#if isInfoPopoverOpen}}true{{else}}false{{/if}}"
        title="QuickDeck Help / Dev"
      >?</button>
    </div>

    <div class="qd40-window-controls">
      <button class="qd40-window-button" type="button" data-action="minimize-overlay" title="Minimize">−</button>
      <button class="qd40-window-button" type="button" data-action="close-overlay" title="Close">×</button>
    </div>
  </div>



  {{#if isInfoPopoverOpen}}
  <div class="qd40-info-popover" role="dialog" aria-label="QuickDeck Help / Dev">
    <div class="qd40-info-title">QuickDeck Help / Dev</div>
    <div class="qd40-info-row"><span>UI</span><strong>{{uiBuildLabel}}</strong></div>
    <div class="qd40-info-row"><span>Module</span><strong>{{moduleVersion}}</strong></div>
    <div class="qd40-info-row"><span>Mode</span><strong>qd40 chromeless command desk</strong></div>
    <div class="qd40-info-row"><span>Branch</span><strong>{{uiBranchLabel}}</strong></div>
    <div class="qd40-info-divider" aria-hidden="true"></div>
    <label class="qd40-info-dev-field">
      <input type="checkbox" data-action="toggle-dev-art-tuner-enabled" {{#if devArtTunerEnabled}}checked{{/if}}>
      <span>
        <strong>Dev Art Tuner</strong>
        <small>Layout/art inspection tools</small>
      </span>
    </label>
  </div>
  {{/if}}

  <div class="qd40-body {{#if isUi2Mode}}qd-ui2-body{{/if}}">
  {{#if isUi2Mode}}
    {{!--
    UI2 v0.14.3 placeholder shell.
    Future passes:
    - actor card
    - roster
    - carousel
    - actions drawer
    - art integration
    --}}
    {{!-- UI2 v0.14.3 is intentionally placeholder-only. Actor card, roster, carousel, and action drawer mapping come in later passes. --}}
    <section
      class="qd40-shell qd-ui2-shell {{#if isRosterDrawerOpen}}qd-ui2-left-open{{else}}qd-ui2-left-collapsed{{/if}} {{#if isActionsDrawerOpen}}qd-ui2-right-open{{else}}qd-ui2-right-collapsed{{/if}}"
      data-active-drawer="{{activeDrawer}}"
      aria-label="QuickDeck UI2 shell"
    >
      <button
        class="qd-ui2-edge-tab qd-ui2-left-tab"
        type="button"
        data-action="toggle-roster-drawer"
        title="{{#if isRosterDrawerOpen}}Collapse Active Characters drawer{{else}}Open Active Characters drawer{{/if}}"
        aria-expanded="{{#if isRosterDrawerOpen}}true{{else}}false{{/if}}"
      >
        <span>{{#if isRosterDrawerOpen}}‹ Close{{else}}Active ›{{/if}}</span>
      </button>

      {{#if isRosterDrawerOpen}}
      <aside class="qd-ui2-drawer qd-ui2-left-drawer" aria-label="UI2 character drawer">
        <header class="qd-ui2-panel-header">
          <p class="qd-ui2-kicker">Roster</p>
          <h2>Characters</h2>
        </header>
        <section class="qd-ui2-active-roster-card" aria-label="Active Characters">
          <h3>Active Characters</h3>
          {{#if hasRosterActors}}
          <div class="qd-ui2-active-roster-list" data-drop-zone="roster">
            {{#each rosterActors as |actor|}}
            <article
              class="qd-ui2-active-roster-row {{#if actor.isActive}}is-active{{/if}}"
              data-action="open-actor"
              data-actor-id="{{actor.id}}"
              title="Select {{actor.name}}"
            >
              <img class="qd-ui2-active-roster-portrait" src="{{actor.img}}" alt="{{actor.name}}" />
              <div class="qd-ui2-active-roster-meta">
                <strong>{{actor.name}}</strong>
                {{#if actor.actorType}}<small>{{actor.actorType}}</small>{{/if}}
              </div>
              <button
                type="button"
                class="qd-ui2-active-roster-remove"
                data-action="remove-actor"
                data-actor-id="{{actor.id}}"
                title="Remove {{actor.name}}"
                aria-label="Remove {{actor.name}}"
              >×</button>
            </article>
            {{/each}}
          </div>
          {{else}}
          <p>No active characters yet. Drop actors here or add them from UI1.</p>
          {{/if}}
        </section>
        <section class="qd-ui2-inactive-roster-card" aria-label="Inactive Characters">
          <header class="qd-ui2-inactive-roster-header">
            <div>
              <h3>Inactive Characters</h3>
              <p>Add available actors to the active roster.</p>
            </div>
            <span class="qd-ui2-inactive-roster-count" data-search-status="available">{{availableSearchStatusText}}</span>
          </header>
          <input
            class="qd-ui2-inactive-roster-search"
            type="search"
            data-action="available-search"
            value="{{availableSearch}}"
            placeholder="Search inactive characters"
            aria-label="Search inactive characters"
          />
          {{#if hasAvailableActors}}
          <div class="qd-ui2-inactive-roster-list">
            {{#each availableActors as |actor|}}
            <article class="qd-ui2-inactive-roster-row" data-search-row="available" data-search-text="{{actor.searchText}}" {{#unless actor.isAvailableSearchMatch}}hidden{{/unless}}>
              <img class="qd-ui2-inactive-roster-portrait" src="{{actor.img}}" alt="{{actor.name}}" />
              <div class="qd-ui2-inactive-roster-meta">
                <strong>{{actor.name}}</strong>
                {{#if actor.actorType}}<small>{{actor.actorType}}</small>{{/if}}
              </div>
              <button
                type="button"
                class="qd-ui2-inactive-roster-add"
                data-action="add-actor"
                data-actor-id="{{actor.id}}"
                title="Add {{actor.name}}"
                aria-label="Add {{actor.name}}"
              >Add</button>
            </article>
            {{/each}}
          </div>
          <p class="qd-ui2-inactive-roster-empty" data-search-empty="available" {{#unless availableSearchShowEmpty}}hidden{{/unless}}>No inactive characters match your search.</p>
          {{else}}
          <p class="qd-ui2-inactive-roster-empty">No inactive characters available.</p>
          {{/if}}
        </section>
      </aside>
      {{/if}}

      <main class="qd-ui2-center-cockpit" aria-label="UI2 center cockpit">
        {{#if activeActor}}
        <section class="qd-ui2-actor-card" aria-label="Selected actor card">
          <div class="qd-ui2-portrait-ring">
            <img class="qd-ui2-actor-portrait" src="{{activeActor.img}}" alt="{{activeActor.name}}" />
          </div>

          <div class="qd-ui2-actor-title-block">
            <h1 class="qd-ui2-actor-name">{{activeActor.name}}</h1>
            {{#if activeActor.actorType}}<p class="qd-ui2-actor-type">{{activeActor.actorType}}</p>{{/if}}
          </div>

          <div class="qd-ui2-vital-stack" aria-label="HP and FP meters">
            <div class="qd-ui2-vital-meter qd-ui2-hp-meter" aria-label="HP {{gurpsData.display.hp}} / {{gurpsData.display.hpMax}}">
              <span class="qd-ui2-vital-fill" style="width: {{gurpsData.hpPercent}}%;"></span>
              <span class="qd-ui2-vital-label">HP</span>
              <span class="qd-ui2-vital-readout">{{gurpsData.display.hp}} / {{gurpsData.display.hpMax}}</span>
            </div>
            <div class="qd-ui2-vital-meter qd-ui2-fp-meter" aria-label="FP {{gurpsData.display.fp}} / {{gurpsData.display.fpMax}}">
              <span class="qd-ui2-vital-fill" style="width: {{gurpsData.fpPercent}}%;"></span>
              <span class="qd-ui2-vital-label">FP</span>
              <span class="qd-ui2-vital-readout">{{gurpsData.display.fp}} / {{gurpsData.display.fpMax}}</span>
            </div>
          </div>

          <div class="qd-ui2-instrument-deck" aria-label="Actor roll and defense instruments">
            <div class="qd-ui2-roll-row" aria-label="Attribute roll controls">
              <div class="qd-ui2-roll-pill qd31-primary-roll-chip" aria-label="Primary roll controls">
                <select class="qd-ui2-roll-select" data-action="primary-roll-select" aria-label="Primary roll target">
                  {{#each primaryRollView.options as |option|}}
                  <option value="{{option.key}}" data-value="{{option.displayValue}}" {{#if option.selected}}selected{{/if}}>{{option.displayLabel}}</option>
                  {{/each}}
                </select>
                <span class="qd-ui2-roll-value qd31-primary-roll-value">{{primaryRollView.selectedValue}}</span>
                <button type="button" class="qd-ui2-roll-button" data-action="roll-primary-attribute" title="Roll selected primary attribute" aria-label="Roll selected primary attribute">🎲</button>
              </div>
              <div class="qd-ui2-roll-pill qd31-secondary-roll-chip" aria-label="Secondary roll controls">
                <select class="qd-ui2-roll-select" data-action="secondary-roll-select" aria-label="Secondary roll target">
                  {{#each secondaryRollView.options as |option|}}
                  <option value="{{option.key}}" data-value="{{option.displayValue}}" {{#if option.selected}}selected{{/if}}>{{option.displayLabel}}</option>
                  {{/each}}
                </select>
                <span class="qd-ui2-roll-value qd31-secondary-roll-value">{{secondaryRollView.selectedValue}}</span>
                <button type="button" class="qd-ui2-roll-button" data-action="roll-secondary-attribute" title="Roll selected secondary attribute" aria-label="Roll selected secondary attribute">🎲</button>
              </div>
            </div>

            <div class="qd-ui2-stat-grid" aria-label="Move and defense values">
              <article class="qd-ui2-stat-tile" aria-label="Move"><span>Move</span><strong>{{gurpsData.display.move}}</strong></article>
              <button class="qd-ui2-stat-tile qd-ui2-stat-button" type="button" data-action="roll-defense" data-actor-id="{{activeActor.id}}" data-defense="dodge" data-value="{{gurpsData.display.dodge}}"><span>Dodge</span><strong>{{gurpsData.display.dodge}}</strong></button>
              <button class="qd-ui2-stat-tile qd-ui2-stat-button" type="button" data-action="roll-defense" data-actor-id="{{activeActor.id}}" data-defense="parry" data-value="{{gurpsData.display.parry}}"><span>Parry</span><strong>{{gurpsData.display.parry}}</strong></button>
              <button class="qd-ui2-stat-tile qd-ui2-stat-button" type="button" data-action="roll-defense" data-actor-id="{{activeActor.id}}" data-defense="block" data-value="{{gurpsData.display.block}}"><span>Block</span><strong>{{gurpsData.display.block}}</strong></button>
            </div>
          </div>
        </section>
        {{else}}
        <section class="qd-ui2-placeholder-card qd-ui2-center-placeholder">
          <h2>No Actor Selected</h2>
          <p>Open the roster drawer to add/select a character.</p>
        </section>
        {{/if}}

        {{#if hasRosterActors}}
        <section class="qd-ui2-carousel-card" aria-label="Active actor selector carousel">
          <button
            type="button"
            class="qd-ui2-carousel-arrow qd-ui2-carousel-arrow-left"
            data-action="ui2-carousel-scroll"
            data-carousel-direction="prev"
            title="Scroll active actors left"
            aria-label="Scroll active actors left"
          >‹</button>
          <div class="qd-ui2-carousel-track" data-ui2-carousel-track tabindex="0" aria-label="Active roster actor portraits">
            {{#each rosterActors as |actor|}}
            <button
              type="button"
              class="qd-ui2-carousel-portrait-button {{#if actor.isActive}}is-active{{/if}}"
              data-action="open-actor"
              data-actor-id="{{actor.id}}"
              title="Select {{actor.name}}"
              aria-label="Select {{actor.name}}"
              aria-current="{{#if actor.isActive}}true{{else}}false{{/if}}"
            >
              <img class="qd-ui2-carousel-portrait" src="{{actor.img}}" alt="{{actor.name}}" />
            </button>
            {{/each}}
          </div>
          <button
            type="button"
            class="qd-ui2-carousel-arrow qd-ui2-carousel-arrow-right"
            data-action="ui2-carousel-scroll"
            data-carousel-direction="next"
            title="Scroll active actors right"
            aria-label="Scroll active actors right"
          >›</button>
        </section>
        {{/if}}
      </main>

      {{#if isActionsDrawerOpen}}
      <aside class="qd-ui2-drawer qd-ui2-right-drawer" aria-label="UI2 action drawer">
        <header class="qd-ui2-panel-header">
          <h2>Actions</h2>
        </header>

        <nav class="qd-ui2-drawer-tabs" aria-label="UI2 action drawer sections">
          <button type="button" class="qd-ui2-drawer-tab {{#if isCombatDrawerOpen}}is-active{{/if}}" data-action="toggle-drawer" data-drawer="combat">Combat</button>
          <button type="button" class="qd-ui2-drawer-tab {{#if isSkillsDrawerOpen}}is-active{{/if}}" data-action="toggle-drawer" data-drawer="skills">Skills</button>
          <button type="button" class="qd-ui2-drawer-tab {{#if isSpellsDrawerOpen}}is-active{{/if}}" data-action="toggle-drawer" data-drawer="spells">Spells</button>
          <button type="button" class="qd-ui2-drawer-tab {{#if isSettingsDrawerOpen}}is-active{{/if}}" data-action="toggle-drawer" data-drawer="settings">Settings</button>
        </nav>

        <div class="qd-ui2-drawer-scroll" data-qd-native-scroll="true">
          <section class="qd-ui2-drawer-section qd-ui2-combat-section" aria-label="Combat actions">
            <header class="qd-ui2-section-header">
              <h3>Combat</h3>
              <span data-search-status="combat">{{combatSearchStatusText}}</span>
            </header>
            <div class="qd-ui2-search-row">
              <input type="search" data-action="combat-search" value="{{combatSearch}}" placeholder="Search attacks" aria-label="Search attacks" />
              <button type="button" class="qd-ui2-search-clear" data-action="clear-combat-search" {{#unless combatSearchHasQuery}}hidden{{/unless}} title="Clear combat search">Clear</button>
            </div>
            <div class="qd-ui2-search-empty" data-search-empty="combat" {{#unless combatSearchShowEmpty}}hidden{{/unless}}>No matching attacks.</div>
            {{#if activeActor}}
              {{#each indexedAttacks as |attack|}}
              <article class="qd-ui2-action-row {{#if attack.isFavoriteAttack}}is-favorite{{/if}}" data-search-row="combat" data-search-text="{{attack.searchText}}">
                <div class="qd-ui2-action-main">
                  <button type="button" class="qd-ui2-reference-button" data-action="open-reference" data-ref-type="attack" data-ref-name="{{attack.name}}" data-ref-page="{{attack.reference}}" {{#unless attack.reference}}disabled{{/unless}} title="Open attack reference">{{attack.name}}</button>
                  <div class="qd-ui2-action-meta">
                    {{#if attack.type}}<span>Type: {{attack.type}}</span>{{/if}}
                    {{#if attack.mode}}<span>Mode: {{attack.mode}}</span>{{/if}}
                    {{#if attack.damageDisplay}}<span>Damage: {{attack.damageDisplay}}</span>{{else if attack.damage}}<span>Damage: {{attack.damage}}</span>{{/if}}
                  </div>
                </div>
                <div class="qd-ui2-action-controls">
                  <button type="button" class="qd-ui2-action-button" data-action="target-opponent" data-actor-id="{{../activeActor.id}}" data-attack-index="{{attack.index}}" title="Target Opponent">🎯</button>
                  <button type="button" class="qd-ui2-action-button" data-action="open-modifier-bucket" data-actor-id="{{../activeActor.id}}" title="Modifier Bucket">🧮</button>
                  <button type="button" class="qd-ui2-action-button {{#if attack.isFavoriteAttack}}is-active{{/if}}" data-action="toggle-favorite-attack" data-actor-id="{{../activeActor.id}}" data-attack-key="{{attack.attackKey}}" title="{{attack.favoriteToggleLabel}}">📌</button>
                  <button type="button" class="qd-ui2-action-button" data-action="roll-attack" data-actor-id="{{../activeActor.id}}" data-attack-index="{{attack.index}}" title="Attack Roll">⚔</button>
                  <button type="button" class="qd-ui2-action-button" data-action="roll-damage" data-actor-id="{{../activeActor.id}}" data-attack-index="{{attack.index}}" title="Damage Roll">💥</button>
                  {{#if attack.reference}}<button type="button" class="qd-ui2-action-button" data-action="open-reference" data-ref-type="attack" data-ref-name="{{attack.name}}" data-ref-page="{{attack.reference}}" title="Reference">ℹ</button>{{/if}}
                </div>
              </article>
              {{else}}
              <p class="qd-ui2-empty-note">No attacks found for this actor.</p>
              {{/each}}
            {{else}}
              <p class="qd-ui2-empty-note">Select an actor to show combat actions.</p>
            {{/if}}
          </section>

          <section class="qd-ui2-drawer-section qd-ui2-skills-section" aria-label="Skill actions">
            <header class="qd-ui2-section-header">
              <h3>Skills</h3>
              <span data-search-status="skills">{{skillsSearchStatusText}}</span>
            </header>
            <div class="qd-ui2-search-row">
              <input type="search" data-action="skills-search" value="{{skillsSearch}}" placeholder="Search skills" aria-label="Search skills" />
              <button type="button" class="qd-ui2-search-clear" data-action="clear-skills-search" {{#unless skillsSearchHasQuery}}hidden{{/unless}} title="Clear skills search">Clear</button>
            </div>
            <div class="qd-ui2-search-empty" data-search-empty="skills" {{#unless skillsSearchShowEmpty}}hidden{{/unless}}>No matching skills.</div>
            {{#if activeActor}}
              {{#each indexedSkills as |skill|}}
              <article class="qd-ui2-action-row {{#if skill.isQuickSkillSelected}}is-favorite{{/if}}" data-search-row="skills" data-search-text="{{skill.searchText}}">
                <div class="qd-ui2-action-main">
                  <button type="button" class="qd-ui2-reference-button" data-action="open-reference" data-ref-type="skill" data-ref-name="{{skill.name}}" data-ref-page="{{skill.referenceDisplay}}" title="Open skill reference">{{skill.name}}</button>
                  <div class="qd-ui2-action-meta">
                    {{#if skill.relativeLevelDisplay}}<span>Level: {{skill.relativeLevelDisplay}}</span>{{else}}<span>Level: {{skill.levelDisplay}}</span>{{/if}}
                    {{#if skill.specialization}}<span>Spec: {{skill.specialization}}</span>{{/if}}
                  </div>
                </div>
                <div class="qd-ui2-action-controls">
                  <button type="button" class="qd-ui2-action-button" data-action="roll-skill" data-actor-id="{{../activeActor.id}}" data-skill-index="{{skill.index}}" title="Roll Skill">🎲</button>
                  <button type="button" class="qd-ui2-action-button {{#if skill.isQuickSkillSelected}}is-active{{/if}}" data-action="toggle-quick-skill" data-actor-id="{{../activeActor.id}}" data-skill-key="{{skill.quickSkillKey}}" title="{{skill.quickSkillToggleLabel}}">📌</button>
                  <button type="button" class="qd-ui2-action-button" data-action="open-reference" data-ref-type="skill" data-ref-name="{{skill.name}}" data-ref-page="{{skill.referenceDisplay}}" title="Reference">ℹ</button>
                </div>
              </article>
              {{else}}
              <p class="qd-ui2-empty-note">No skills found for this actor.</p>
              {{/each}}
            {{else}}
              <p class="qd-ui2-empty-note">Select an actor to show skills.</p>
            {{/if}}
          </section>

          <section class="qd-ui2-drawer-section qd-ui2-spells-section" aria-label="Spell actions">
            <header class="qd-ui2-section-header">
              <h3>Spells</h3>
              <span data-search-status="spells">{{spellsSearchStatusText}}</span>
            </header>
            <div class="qd-ui2-search-row">
              <input type="search" data-action="spells-search" value="{{spellsSearch}}" placeholder="Search spells" aria-label="Search spells" />
              <button type="button" class="qd-ui2-search-clear" data-action="clear-spells-search" {{#unless spellsSearchHasQuery}}hidden{{/unless}} title="Clear spells search">Clear</button>
            </div>
            <div class="qd-ui2-search-empty" data-search-empty="spells" {{#unless spellsSearchShowEmpty}}hidden{{/unless}}>No matching spells.</div>
            {{#if activeActor}}
              {{#each indexedSpells as |spell|}}
              <article class="qd-ui2-action-row {{#if spell.isFavoriteSpell}}is-favorite{{/if}}" data-search-row="spells" data-search-text="{{spell.searchText}}">
                <div class="qd-ui2-action-main">
                  <button type="button" class="qd-ui2-reference-button" data-action="open-reference" data-ref-type="spell" data-ref-name="{{spell.name}}" data-ref-page="{{spell.reference}}" title="Open spell reference">{{spell.name}}</button>
                  <div class="qd-ui2-action-meta">
                    {{#if spell.class}}<span>Class: {{spell.class}}</span>{{/if}}
                    {{#if spell.college}}<span>College: {{spell.college}}</span>{{/if}}
                  </div>
                </div>
                <div class="qd-ui2-action-controls">
                  <button type="button" class="qd-ui2-action-button" data-action="target-action" title="Target">🎯</button>
                  <button type="button" class="qd-ui2-action-button" data-action="open-modifier-bucket" data-actor-id="{{../activeActor.id}}" title="Modifier Bucket">🧮</button>
                  <button type="button" class="qd-ui2-action-button {{#if spell.isFavoriteSpell}}is-active{{/if}}" data-action="toggle-favorite-spell" data-actor-id="{{../activeActor.id}}" data-spell-key="{{spell.spellKey}}" title="{{spell.favoriteToggleLabel}}">📌</button>
                  <button type="button" class="qd-ui2-action-button" data-action="roll-spell" data-actor-id="{{../activeActor.id}}" data-spell-index="{{spell.index}}" title="Roll Spell">✨</button>
                  <button type="button" class="qd-ui2-action-button" data-action="open-reference" data-ref-type="spell" data-ref-name="{{spell.name}}" data-ref-page="{{spell.reference}}" title="Reference">ℹ</button>
                </div>
              </article>
              {{else}}
              <p class="qd-ui2-empty-note">No spells found for this actor.</p>
              {{/each}}
            {{else}}
              <p class="qd-ui2-empty-note">Select an actor to show spells.</p>
            {{/if}}
          </section>

          <section class="qd-ui2-drawer-section qd-ui2-settings-section" aria-label="Settings">
            <header class="qd-ui2-section-header">
              <h3>Settings</h3>
              <span>UI mode</span>
            </header>
            <div class="qd-ui2-settings-stack">
              <label class="qd-ui2-mode-field">
                <input type="checkbox" data-action="set-ui-mode" {{#if isUi2Mode}}checked{{/if}}>
                <span>Enable UI2 Experimental Shell</span>
              </label>
              {{#if devArtTunerEnabled}}
              <div class="qd-ui2-settings-actions">
                <button type="button" class="qd-ui2-action-button qd-ui2-text-button" data-action="open-dev-art-tuner" title="Open Art Tuner">Open</button>
                <button type="button" class="qd-ui2-action-button qd-ui2-text-button" data-action="close-dev-art-tuner" title="Close Art Tuner">Close</button>
                <button type="button" class="qd-ui2-action-button qd-ui2-text-button" data-action="copy-dev-art-tuner-css" title="Copy Art Tuner CSS">Copy CSS</button>
                <button type="button" class="qd-ui2-action-button qd-ui2-text-button" data-action="reset-dev-art-tuner" title="Reset Art Tuner">Reset</button>
                <button type="button" class="qd-ui2-action-button qd-ui2-text-button" data-action="status-dev-art-tuner" title="Log Art Tuner Status">Status</button>
              </div>
              <p class="qd-ui2-empty-note">Developer-only visual layout tool · temporary CSS only.</p>
              {{/if}}
              <p class="qd-ui2-empty-note">Additional QuickDeck settings remain available in UI1 while UI2 mapping continues.</p>
            </div>
          </section>
        </div>
      </aside>
      {{/if}}

      <button
        class="qd-ui2-edge-tab qd-ui2-right-tab"
        type="button"
