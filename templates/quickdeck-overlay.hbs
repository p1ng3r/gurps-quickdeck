<div class="qd40-frame qd-ui2-frame">
  <div class="qd40-chrome-row" data-action="drag-overlay" title="Drag QuickDeck">
    <div class="qd40-corner-badge">
      <span class="qd40-corner-title">GURPS QuickDeck</span>
      <button
        type="button"
        class="qd40-info-button"
        data-action="toggle-info-popover"
        aria-expanded="{{#if isInfoPopoverOpen}}true{{else}}false{{/if}}"
        title="QuickDeck version info"
      >?</button>
    </div>

    <div class="qd40-window-controls">
      <button class="qd40-window-button" type="button" data-action="minimize-overlay" title="Minimize">−</button>
      <button class="qd40-window-button" type="button" data-action="close-overlay" title="Close">×</button>
    </div>
  </div>



  {{#if isInfoPopoverOpen}}
  <div class="qd40-info-popover" role="dialog" aria-label="QuickDeck version information">
    <div class="qd40-info-title">GURPS QuickDeck</div>
    <div class="qd40-info-row"><span>UI</span><strong>{{uiBuildLabel}}</strong></div>
    <div class="qd40-info-row"><span>Module</span><strong>{{moduleVersion}}</strong></div>
    <div class="qd40-info-row"><span>Mode</span><strong>qd40 chromeless command desk</strong></div>
    <div class="qd40-info-row"><span>Branch</span><strong>{{uiBranchLabel}}</strong></div>
  </div>
  {{/if}}

  <div class="qd40-body qd-ui2-body">
    {{!-- UI2 v0.14.3 is intentionally placeholder-only. Actor card, roster, carousel, and action drawer mapping come in later passes. --}}
    <section
      class="qd40-shell qd-ui2-shell {{#if isRosterDrawerOpen}}qd-ui2-left-open{{else}}qd-ui2-left-collapsed{{/if}} {{#if isActionsDrawerOpen}}qd-ui2-right-open{{else}}qd-ui2-right-collapsed{{/if}}"
      data-active-drawer="{{activeDrawer}}"
      aria-label="QuickDeck UI2 shell"
    >
      <button
        class="qd-ui2-edge-tab qd-ui2-left-tab"
        type="button"
        data-action="toggle-roster-drawer"
        title="{{#if isRosterDrawerOpen}}Collapse Active Characters drawer{{else}}Open Active Characters drawer{{/if}}"
        aria-expanded="{{#if isRosterDrawerOpen}}true{{else}}false{{/if}}"
      >
        <span>{{#if isRosterDrawerOpen}}‹ Close{{else}}Active ›{{/if}}</span>
      </button>

      {{#if isRosterDrawerOpen}}
      <aside class="qd-ui2-drawer qd-ui2-left-drawer" aria-label="UI2 character drawer">
        <header class="qd-ui2-panel-header">
          <p class="qd-ui2-kicker">Roster Shell</p>
          <h2>Characters</h2>
        </header>
        <section class="qd-ui2-placeholder-card">
          <h3>Active Characters</h3>
          <p>Placeholder for the active-character roster panel.</p>
        </section>
        <section class="qd-ui2-placeholder-card qd-ui2-muted-card">
          <h3>Inactive Characters</h3>
          <p>Placeholder for available or inactive character entries.</p>
        </section>
      </aside>
      {{/if}}

      <main class="qd-ui2-center-cockpit" aria-label="UI2 center cockpit">
        <header class="qd-ui2-panel-header qd-ui2-center-header">
          <p class="qd-ui2-kicker">QD v0.14.3 — shell HTML</p>
          <h1>UI2 Center Cockpit</h1>
        </header>
        <section class="qd-ui2-placeholder-card qd-ui2-center-placeholder">
          <h2>UI2 Center Cockpit placeholder</h2>
          <p>Shell-only layout pass. Actor cards, carousel content, art integration, and action wiring land later.</p>
        </section>
      </main>

      {{#if isActionsDrawerOpen}}
      <aside class="qd-ui2-drawer qd-ui2-right-drawer" aria-label="UI2 action drawer">
        <header class="qd-ui2-panel-header">
          <p class="qd-ui2-kicker">Action Shell</p>
          <h2>Drawers</h2>
        </header>
        <section class="qd-ui2-placeholder-card"><h3>Combat</h3><p>Combat placeholder.</p></section>
        <section class="qd-ui2-placeholder-card"><h3>Skills</h3><p>Skills placeholder.</p></section>
        <section class="qd-ui2-placeholder-card"><h3>Spells</h3><p>Spells placeholder.</p></section>
        <section class="qd-ui2-placeholder-card qd-ui2-settings-card">
          <h3>Settings</h3>
          <p>Settings placeholder.</p>
          <label class="qd-ui2-mode-field">
            <span>UI Mode</span>
            <select data-action="set-ui-mode" aria-label="QuickDeck UI Mode">
              <option value="ui1" {{#if isUi1Mode}}selected{{/if}}>UI1 / Current UI</option>
              <option value="ui2" {{#if isUi2Mode}}selected{{/if}}>UI2 / Experimental UI</option>
            </select>
          </label>
        </section>
      </aside>
      {{/if}}

      <button
        class="qd-ui2-edge-tab qd-ui2-right-tab"
        type="button"
        data-action="toggle-actions-drawer"
        data-drawer="combat"
        title="{{#if isActionsDrawerOpen}}Collapse action drawer{{else}}Open action drawer{{/if}}"
        aria-expanded="{{#if isActionsDrawerOpen}}true{{else}}false{{/if}}"
      >
        <span>{{#if isActionsDrawerOpen}}Close ›{{else}}‹ Actions{{/if}}</span>
      </button>
    </section>
  </div>
</div>
