        <button type="button" class="qd31-square-button" data-action="roll-attack" data-actor-id="{{../activeActor.id}}" data-attack-index="{{attack.index}}" title="Attack Roll">⚔</button>
        <button type="button" class="qd31-square-button" data-action="roll-damage" data-actor-id="{{../activeActor.id}}" data-attack-index="{{attack.index}}" title="Damage Roll">💥</button>
        {{#if attack.reference}}<button type="button" class="qd31-square-button" data-action="open-reference" data-ref-type="attack" data-ref-name="{{attack.name}}" data-ref-page="{{attack.reference}}" title="Reference">ℹ</button>{{/if}}
      </div></div>
      {{/each}}
    </section>
    <section class="qd31-drawer-body" {{#unless isSkillsDrawerOpen}}hidden{{/unless}}>
      <div class="qd31-search-row">
        <input type="search" data-action="skills-search" value="{{skillsSearch}}" placeholder="Search skills" />
        <button type="button" class="qd31-search-clear" data-action="clear-skills-search" {{#unless skillsSearchHasQuery}}hidden{{/unless}} title="Clear skills search">Clear</button>
        <span class="qd31-search-status" data-search-status="skills">{{skillsSearchStatusText}}</span>
      </div>
      <div class="qd31-search-empty" data-search-empty="skills" {{#unless skillsSearchShowEmpty}}hidden{{/unless}}>No matching skills.</div>
      {{#each indexedSkills as |skill|}}
      <div class="qd31-action-row {{#if skill.isQuickSkillSelected}}is-favorite{{/if}}" data-search-row="skills" data-search-text="{{skill.searchText}}"><div class="qd31-action-main"><button type="button" class="qd31-reference-button" data-action="open-reference" data-ref-type="skill" data-ref-name="{{skill.name}}" data-ref-page="{{skill.referenceDisplay}}" title="Open skill reference"><strong>{{skill.name}}</strong></button>{{#if skill.relativeLevelDisplay}}<small class="qd31-action-meta-item"><span class="qd31-action-meta-label">Level</span><span class="qd31-action-meta-value">{{skill.relativeLevelDisplay}}</span></small>{{/if}}{{#if skill.specialization}}<small class="qd31-action-meta-item"><span class="qd31-action-meta-label">Spec</span><span class="qd31-action-meta-value">{{skill.specialization}}</span></small>{{/if}}</div><div class="qd31-action-controls">
        <button type="button" class="qd31-square-button" data-action="roll-skill" data-actor-id="{{../activeActor.id}}" data-skill-index="{{skill.index}}" title="Roll Skill">🎲</button>
        <button type="button" class="qd31-square-button {{#if skill.isQuickSkillSelected}}is-active{{/if}}" data-action="toggle-quick-skill" data-actor-id="{{../activeActor.id}}" data-skill-key="{{skill.quickSkillKey}}" title="{{skill.quickSkillToggleLabel}}">📌</button>
        <button type="button" class="qd31-square-button" data-action="open-reference" data-ref-type="skill" data-ref-name="{{skill.name}}" data-ref-page="{{skill.referenceDisplay}}" title="Reference">ℹ</button>
      </div></div>
      {{/each}}
    </section>
    <section class="qd31-drawer-body" {{#unless isSpellsDrawerOpen}}hidden{{/unless}}>
      <div class="qd31-search-row">
        <input type="search" data-action="spells-search" value="{{spellsSearch}}" placeholder="Search spells" />
        <button type="button" class="qd31-search-clear" data-action="clear-spells-search" {{#unless spellsSearchHasQuery}}hidden{{/unless}} title="Clear spells search">Clear</button>
        <span class="qd31-search-status" data-search-status="spells">{{spellsSearchStatusText}}</span>
      </div>
      <div class="qd31-search-empty" data-search-empty="spells" {{#unless spellsSearchShowEmpty}}hidden{{/unless}}>No matching spells.</div>
      {{#each indexedSpells as |spell|}}
      <div class="qd31-action-row {{#if spell.isFavoriteSpell}}is-favorite{{/if}}" data-search-row="spells" data-search-text="{{spell.searchText}}"><div class="qd31-action-main"><button type="button" class="qd31-reference-button" data-action="open-reference" data-ref-type="spell" data-ref-name="{{spell.name}}" data-ref-page="{{spell.reference}}" title="Open spell reference"><strong>{{spell.name}}</strong></button>{{#if spell.class}}<small class="qd31-action-meta-item"><span class="qd31-action-meta-label">Class</span><span class="qd31-action-meta-value">{{spell.class}}</span></small>{{/if}}{{#if spell.college}}<small class="qd31-action-meta-item"><span class="qd31-action-meta-label">College</span><span class="qd31-action-meta-value">{{spell.college}}</span></small>{{/if}}</div><div class="qd31-action-controls">
        <button type="button" class="qd31-square-button" data-action="target-action" title="Target">🎯</button>
        <button type="button" class="qd31-square-button" data-action="open-modifier-bucket" data-actor-id="{{../activeActor.id}}" title="Modifier Bucket">🧮</button>
        <button type="button" class="qd31-square-button {{#if spell.isFavoriteSpell}}is-active{{/if}}" data-action="toggle-favorite-spell" data-actor-id="{{../activeActor.id}}" data-spell-key="{{spell.spellKey}}" title="{{spell.favoriteToggleLabel}}">📌</button>
        <button type="button" class="qd31-square-button" data-action="roll-spell" data-actor-id="{{../activeActor.id}}" data-spell-index="{{spell.index}}" title="Roll Spell">✨</button>
        <button type="button" class="qd31-square-button" data-action="open-reference" data-ref-type="spell" data-ref-name="{{spell.name}}" data-ref-page="{{spell.reference}}" title="Reference">ℹ</button>
      </div></div>
      {{/each}}
    </section>
    <section class="qd31-drawer-body" {{#unless isSettingsDrawerOpen}}hidden{{/unless}}>
      <section class="qd31-settings-panel">
        <header class="qd31-settings-header">
          <h3>Dev Art Tuner</h3>
          <small>Developer-only visual layout tool · temporary CSS only</small>
        </header>
        <div class="qd31-action-row qd31-dev-art-tuner-row">
          <label class="qd31-dev-art-tuner-toggle">
            <input type="checkbox" data-action="set-ui-mode" {{#if isUi2Mode}}checked{{/if}}>
            <span>Enable UI2 Experimental Shell</span>
          </label>
        </div>
        <div class="qd31-action-row qd31-dev-art-tuner-row">
          <label class="qd31-dev-art-tuner-toggle">
            <input type="checkbox" data-action="toggle-dev-art-tuner-enabled" {{#if devArtTunerEnabled}}checked{{/if}}>
            <span>Enable Dev Art Tuner</span>
          </label>
        </div>
        {{#if devArtTunerEnabled}}
        <div class="qd31-action-controls qd31-dev-art-tuner-controls">
          <button type="button" class="qd31-square-button" data-action="open-dev-art-tuner" title="Open Art Tuner">Open</button>
          <button type="button" class="qd31-square-button" data-action="close-dev-art-tuner" title="Close Art Tuner">Close</button>
          <button type="button" class="qd31-square-button" data-action="copy-dev-art-tuner-css" title="Copy Art Tuner CSS">Copy CSS</button>
          <button type="button" class="qd31-square-button" data-action="reset-dev-art-tuner" title="Reset Art Tuner">Reset</button>
          <button type="button" class="qd31-square-button" data-action="status-dev-art-tuner" title="Log Art Tuner Status">Status</button>
        </div>
        <small class="qd31-dev-art-tuner-note">Use Copy CSS to export manual overrides. Reset clears temporary tuner overrides.</small>
        {{/if}}
      </section>
      <section class="qd31-settings-panel">
        <header class="qd31-settings-header">
          <h3>PDF Source Manager</h3>
          <small>User PDFs primary · built-in summaries fallback · no PDF parsing</small>
        </header>
        <section class="qd31-source-priority-panel" aria-label="Source priority">
          <h4>Source Priority</h4>
          <ol>
            <li><strong>Mapped user PDF source</strong> opens externally/browser-linked when available.</li>
            <li><strong>Built-in QuickDeck summaries</strong> provide fallback popup content.</li>
            <li><strong>Reference lookup key/page data</strong> helps resolve source/page targets.</li>
          </ol>
        </section>
        <div class="qd31-pdf-map-form">
          <label>Source Key<input type="text" data-action="pdf-map-key" value="{{pdfMapDraft.key}}" placeholder="B"></label>
          <label>Display Name<input type="text" data-action="pdf-map-name" value="{{pdfMapDraft.name}}" placeholder="Basic Set"></label>
          <small>Known keys auto-fill names. Examples: B, BX, DFA, DFX, DFS, MA, M, DF1:, PU2:.</small>
          <label>PDF Path
            <div class="qd31-pdf-path-row">
              <input type="text" data-action="pdf-map-path" value="{{pdfMapDraft.path}}" placeholder="Choose PDF..." readonly>
              <button type="button" class="qd31-square-button" data-action="choose-pdf-source" title="Choose PDF">📁</button>
            </div>
          </label>
          <label>Page Offset<input type="number" data-action="pdf-map-offset" value="{{pdfMapDraft.offset}}"></label>
          <div class="qd31-pdf-map-actions">
            <button type="button" class="qd31-square-button" data-action="save-pdf-source" title="Save PDF mapping">💾</button>
            <button type="button" class="qd31-square-button" data-action="clear-pdf-source-draft" title="Clear form">✕</button>
          </div>
        </div>
        <div class="qd31-pdf-map-list">
          {{#each pdfPageRefMappings as |mapping|}}
            <article class="qd31-pdf-map-row">
              <div class="qd31-pdf-map-main">
                <div class="qd31-pdf-map-title"><strong>{{mapping.key}}</strong><span>{{mapping.name}}</span></div>
                <small class="qd31-pdf-map-path" title="{{mapping.pathDisplayTooltip}}">{{mapping.pathDisplay}}</small>
                <div class="qd31-pdf-map-diagnostics">
                  <small>{{mapping.statusText}}</small>
                  <small>Offset: {{mapping.offset}}</small>
                  <small>Test opens page: {{mapping.testPage}}</small>
                </div>
              </div>
              <div class="qd31-action-controls qd31-pdf-map-controls">
                <button type="button" class="qd31-square-button" data-action="edit-pdf-source" data-key="{{mapping.key}}" title="Edit">✎</button>
                <button type="button" class="qd31-square-button" data-action="test-pdf-source" data-key="{{mapping.key}}" title="Test Open: page 1 + offset">▶</button>
                <button type="button" class="qd31-square-button" data-action="remove-pdf-source" data-key="{{mapping.key}}" title="Remove">🗑</button>
              </div>
            </article>
          {{else}}
            <div class="qd31-center-fav-empty">No PDFs mapped yet. Add B, MA, M, etc.</div>
          {{/each}}
        </div>
        <div class="qd31-action-row">
          <span>Built-in QuickDeck summaries are still used when no mapped PDF exists.</span>
          <button type="button" class="qd31-square-button" data-action="open-reference-index">Refs</button>
        </div>
      </section>
    </section>
  </aside>
  {{/if}}
  </div>
  </section>
  {{/if}}
  </div>
</div>
