<section class="quickdeck-pdf-sources-shell">
  <header class="quickdeck-reference-panel quickdeck-pdf-sources-header">
    <h2>QuickDeck PDF Sources</h2>
    <p>Store local source metadata for future reference lookup. No PDFs are parsed in this release.</p>
    <p class="quickdeck-pdf-offset-help">Use offset when the PDF page number differs from the printed book page.</p>
  </header>

  <section class="quickdeck-reference-panel quickdeck-pdf-sources-body">
    {{#if hasSources}}
      <ol class="quickdeck-pdf-sources-list">
        {{#each sources as |source|}}
          <li class="quickdeck-pdf-source-row" data-source-row data-index="{{source.index}}">
            <div class="quickdeck-pdf-source-grid">
              <label>
                <span>Display name</span>
                <input type="text" data-field="displayName" value="{{source.displayName}}" placeholder="Basic Set Campaigns" />
              </label>
              <label>
                <span>Book key / ID</span>
                <input type="text" data-field="bookKey" value="{{source.bookKey}}" placeholder="basic-campaigns" />
              </label>
              <label>
                <span>File/path hint</span>
                <div class="quickdeck-pdf-file-hint-row">
                  <input type="text" data-field="fileHint" value="{{source.fileHint}}" placeholder="Data/pdfs/GURPS-Basic-Campaigns.pdf" />
                  <button type="button" class="quickdeck-open-sheet-button quickdeck-pdf-file-picker-button" data-action="pick-file-hint" data-index="{{source.index}}" title="Pick local PDF file">
                    Pick
                  </button>
                </div>
              </label>
              <label>
                <span>Page offset</span>
                <div class="quickdeck-pdf-offset-controls">
                  <input type="number" data-field="pageOffset" value="{{source.pageOffset}}" />
                  <input
                    type="range"
                    data-helper="pageOffsetSlider"
                    min="{{../pageOffsetSliderMin}}"
                    max="{{../pageOffsetSliderMax}}"
                    step="1"
                    value="{{source.pageOffset}}"
                  />
                </div>
              </label>

              <div class="quickdeck-pdf-offset-helper" aria-live="polite">
                <label>
                  <span>Sample displayed/book page</span>
                  <input type="number" data-helper="sampleBookPage" value="{{../defaultSampleBookPage}}" />
                </label>
                <label>
                  <span>Computed PDF page preview</span>
                  <input type="number" data-helper="computedPdfPage" value="{{../defaultSampleBookPage}}" readonly />
                </label>
                <p class="quickdeck-pdf-offset-preview" data-helper="offsetPreviewText">
                  Book page {{../defaultSampleBookPage}} + offset {{source.pageOffset}} = PDF page {{../defaultSampleBookPage}}
                </p>
              </div>

              <label class="quickdeck-pdf-source-notes">
                <span>Notes</span>
                <textarea data-field="notes" rows="2" placeholder="Optional personal note">{{source.notes}}</textarea>
              </label>
            </div>
            <button type="button" class="quickdeck-remove-button" data-action="remove-source" data-index="{{source.index}}">
              Remove
            </button>
          </li>
        {{/each}}
      </ol>
    {{else}}
      <p class="quickdeck-reference-empty"><em>No sources configured yet. Add one to get started.</em></p>
    {{/if}}

    <footer class="quickdeck-pdf-sources-actions">
      <button type="button" class="quickdeck-add-button" data-action="add-source">Add Source</button>
      <button type="button" class="quickdeck-roll-button" data-action="save-sources">Save Sources</button>
    </footer>
  </section>
</section>
