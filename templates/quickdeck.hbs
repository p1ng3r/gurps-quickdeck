<section class="qd31-shell {{#if isRosterDrawerOpen}}qd31-left-open{{/if}} {{#if isActionsDrawerOpen}}qd31-right-open{{/if}}" data-active-drawer="{{activeDrawer}}">
  {{#unless isRosterDrawerOpen}}
  <div class="qd31-left-tab-slot">
    <button class="qd31-left-pull-tab" type="button" data-action="toggle-roster-drawer">Roster</button>
  </div>
  {{/unless}}
  <aside class="qd31-left-drawer" {{#unless isRosterDrawerOpen}}hidden{{/unless}}>
    <header class="qd31-drawer-header">
      <h3>Active Roster</h3>
      <button type="button" class="qd31-square-button qd31-trash-button" data-action="clear-roster" title="Clear roster">🗑</button>
    </header>
    <div class="qd31-roster-list" data-drop-zone="roster">
      {{#each rosterActors as |actor|}}
      <article class="qd31-roster-card {{#if actor.isActive}}is-active{{/if}}" data-action="open-actor" data-actor-id="{{actor.id}}">
        <img class="qd31-roster-portrait" src="{{actor.img}}" alt="{{actor.name}}" />
        <div class="qd31-roster-meta" title="{{actor.actorType}}">
          <strong class="qd31-roster-name">{{actor.name}}</strong>
          <div class="qd31-mini-bars">
            <div class="qd31-mini-row qd31-mini-row-hp"><span>HP {{actor.hpDisplay}}/{{actor.hpMaxDisplay}}</span><div class="qd31-mini-fill"><span style="width: {{actor.hpPercent}}%;"></span></div></div>
            <div class="qd31-mini-row qd31-mini-row-fp"><span>FP {{actor.fpDisplay}}/{{actor.fpMaxDisplay}}</span><div class="qd31-mini-fill"><span style="width: {{actor.fpPercent}}%;"></span></div></div>
          </div>
        </div>
        <button type="button" class="qd31-square-button qd31-roster-remove" data-action="remove-actor" data-actor-id="{{actor.id}}" title="Remove actor">×</button>
      </article>
      {{/each}}
    </div>

    <details class="qd31-available-section" open>
      <summary class="qd31-available-summary">
        <h4>Actors to Add</h4>
        <span class="qd31-available-toggle" aria-hidden="true">▾</span>
      </summary>
      <div class="qd31-available-content">
        <input type="search" data-action="available-search" value="{{availableSearch}}" placeholder="Search actors" />
        <div class="qd31-available-list">
        {{#each availableActors as |actor|}}
          <div class="qd31-action-row qd31-available-row" data-search-row data-search-text="{{actor.searchText}}">
            <img class="qd31-available-portrait" src="{{actor.img}}" alt="{{actor.name}}" />
            <span class="qd31-available-name" title="{{actor.name}}">{{actor.name}}</span>
            <button type="button" class="qd31-square-button qd31-add-actor-button" data-action="add-actor" data-actor-id="{{actor.id}}" title="Add {{actor.name}}">+</button>
          </div>
        {{/each}}
        </div>
      </div>
    </details>
  </aside>

  <section class="qd31-center-cockpit">
    <header class="qd31-header"><div class="quickdeck-dev-badge">{{uiBuildLabel}}</div><h2>QuickDeck Cockpit</h2></header>
    {{#if activeActor}}
    <section class="qd31-actor-card">
      <header class="quickdeck-actor-header"><img class="qd31-actor-portrait qd31-actor-sheet-link" src="{{activeActor.img}}" alt="{{activeActor.name}}" data-action="open-active-actor-sheet" data-actor-id="{{activeActor.id}}" /><div class="quickdeck-actor-identity"><h3 class="qd31-actor-name-link qd31-actor-sheet-link" data-action="open-active-actor-sheet" data-actor-id="{{activeActor.id}}">{{activeActor.name}}</h3><p>{{activeActor.actorType}}</p></div></header>
      <div class="qd31-command-icon-row">
        <button type="button" class="qd31-icon-button" data-action="drop-token" data-actor-id="{{activeActor.id}}" title="Drop Token">♟</button>
        <button type="button" class="qd31-icon-button" data-action="open-sheet" data-actor-id="{{activeActor.id}}" title="Open Sheet">📄</button>
        <button type="button" class="qd31-icon-button" data-action="open-chat" title="Chat">💬</button>
        <button type="button" class="qd31-icon-button" data-action="clear-targets" title="Clear Targets">🎯</button>
        <button type="button" class="qd31-icon-button" data-action="next-actor" title="Next Actor">⏭</button>
        <button type="button" class="qd31-icon-button" data-action="repeat-last-attack" title="Repeat Last Attack" {{#unless canRepeatLastAttack}}disabled{{/unless}}>↻</button>
        <button type="button" class="qd31-icon-button" data-action="open-modifier-bucket" data-actor-id="{{activeActor.id}}" title="Modifier Bucket">🧮</button>
        <button type="button" class="qd31-icon-button" data-action="open-actions-drawer" data-drawer="combat" title="Open Actions">⚔</button>
      </div>

      <div class="qd31-resource-grid">
        <article class="qd31-resource-card">
          <div class="qd31-resource-icon" aria-hidden="true">❤️</div>
          <div class="qd31-resource-value">HP {{gurpsData.display.hp}} / {{gurpsData.display.hpMax}}</div>
          <div class="qd31-resource-controls">
            <button type="button" class="qd31-square-button" data-action="adjust-resource" data-actor-id="{{activeActor.id}}" data-resource="hp" data-delta="-1">−</button>
            <input type="number" class="qd31-resource-input" data-action="set-resource" data-actor-id="{{activeActor.id}}" data-resource="hp" value="{{gurpsData.display.hp}}" />
            <button type="button" class="qd31-square-button" data-action="adjust-resource" data-actor-id="{{activeActor.id}}" data-resource="hp" data-delta="1">+</button>
          </div>
          <div class="qd31-resource-bar"><span style="width: {{gurpsData.hpPercent}}%;"></span></div>
        </article>
        <article class="qd31-resource-card">
          <div class="qd31-resource-icon" aria-hidden="true">⚡</div>
          <div class="qd31-resource-value">FP {{gurpsData.display.fp}} / {{gurpsData.display.fpMax}}</div>
          <div class="qd31-resource-controls">
            <button type="button" class="qd31-square-button" data-action="adjust-resource" data-actor-id="{{activeActor.id}}" data-resource="fp" data-delta="-1">−</button>
            <input type="number" class="qd31-resource-input" data-action="set-resource" data-actor-id="{{activeActor.id}}" data-resource="fp" value="{{gurpsData.display.fp}}" />
            <button type="button" class="qd31-square-button" data-action="adjust-resource" data-actor-id="{{activeActor.id}}" data-resource="fp" data-delta="1">+</button>
          </div>
          <div class="qd31-resource-bar"><span style="width: {{gurpsData.fpPercent}}%;"></span></div>
        </article>
        <article class="qd31-resource-card qd31-move-card">
          <div class="qd31-resource-icon" aria-hidden="true">👟</div>
          <div class="qd31-resource-value">Move {{gurpsData.display.move}}</div>
        </article>
      </div>

      <div class="qd31-defense-grid"><button class="qd31-defense-dial" type="button" data-action="roll-defense" data-actor-id="{{activeActor.id}}" data-defense="dodge" data-value="{{gurpsData.display.dodge}}">Dodge <span>{{gurpsData.display.dodge}}</span></button><button class="qd31-defense-dial" type="button" data-action="roll-defense" data-actor-id="{{activeActor.id}}" data-defense="parry" data-value="{{gurpsData.display.parry}}">Parry <span>{{gurpsData.display.parry}}</span></button><button class="qd31-defense-dial" type="button" data-action="roll-defense" data-actor-id="{{activeActor.id}}" data-defense="block" data-value="{{gurpsData.display.block}}">Block <span>{{gurpsData.display.block}}</span></button></div>

      <div class="qd31-pinned-grid">
        {{#if hasPinnedActions}}
          {{#each pinnedActions as |entry|}}
            <button type="button" class="qd31-pinned-action" data-action="{{entry.action}}" data-actor-id="{{entry.actorId}}" data-{{entry.type}}-index="{{entry.index}}" title="{{entry.label}}">
              <span class="qd31-pinned-action-name">{{entry.label}}</span>
              <span class="qd31-pinned-action-badge">{{entry.badge}}</span>
              <span class="qd31-pinned-action-remove" role="button" aria-label="Remove {{entry.label}} from Quick Actions" title="Remove from Quick Actions" data-action="remove-pinned-action" data-actor-id="{{entry.actorId}}" data-pin-type="{{entry.type}}" data-pin-key="{{entry.key}}">✕</span>
            </button>
          {{/each}}
        {{else}}
          <div class="qd31-pinned-empty-state">Pin up to 5 actions from the drawers.</div>
          <button type="button" class="qd31-square-button" data-action="open-actions-drawer" data-drawer="combat">Attack</button>
          <button type="button" class="qd31-square-button" data-action="open-actions-drawer" data-drawer="skills">Skill</button>
          <button type="button" class="qd31-square-button" data-action="open-actions-drawer" data-drawer="spells">Spell</button>
          <button type="button" class="qd31-square-button" data-action="open-actions-drawer" data-drawer="combat">More</button>
        {{/if}}
      </div>
    </section>
    {{/if}}
  </section>

  <aside class="qd31-right-drawer" {{#unless isActionsDrawerOpen}}hidden{{/unless}}>
    <nav class="qd31-drawer-tabs"><button data-action="toggle-drawer" data-drawer="combat">Combat</button><button data-action="toggle-drawer" data-drawer="skills">Skills</button><button data-action="toggle-drawer" data-drawer="spells">Spells</button><button data-action="toggle-drawer" data-drawer="settings">Settings</button></nav>
    <section class="qd31-drawer-body" {{#unless isCombatDrawerOpen}}hidden{{/unless}}><div class="qd31-action-row"><span>Target</span><button type="button" class="qd31-square-button" data-action="target-action">🎯</button></div><input type="search" data-action="combat-search" value="{{combatSearch}}" placeholder="Search attacks" />
      {{#each indexedAttacks as |attack|}}
      <div class="qd31-action-row" data-search-row data-search-text="{{attack.searchText}}"><div><button type="button" class="qd31-reference-button" data-action="open-reference" data-ref-type="attack" data-ref-name="{{attack.name}}" data-ref-page="{{attack.reference}}" {{#unless attack.reference}}disabled{{/unless}} title="Open attack reference"><strong>{{attack.name}}</strong></button>{{#if attack.type}}<small>{{attack.type}}</small>{{/if}}</div><div>
        <button type="button" class="qd31-square-button" data-action="toggle-pin-attack" data-actor-id="{{../activeActor.id}}" data-attack-key="{{attack.attackKey}}" title="{{#if attack.isPinnedAction}}Remove from Quick Actions{{else}}Pin to Quick Actions{{/if}}">{{#if attack.isPinnedAction}}★{{else}}☆{{/if}}</button>
        <button type="button" class="qd31-square-button" data-action="roll-attack" data-actor-id="{{../activeActor.id}}" data-attack-index="{{attack.index}}">Atk</button>
        <button type="button" class="qd31-square-button" data-action="roll-damage" data-actor-id="{{../activeActor.id}}" data-attack-index="{{attack.index}}">Dmg</button>
        {{#if attack.reference}}<button type="button" class="qd31-square-button" data-action="open-reference" data-ref-type="attack" data-ref-name="{{attack.name}}" data-ref-page="{{attack.reference}}">Ref</button>{{/if}}
      </div></div>
      {{/each}}
    </section>
    <section class="qd31-drawer-body" {{#unless isSkillsDrawerOpen}}hidden{{/unless}}><input type="search" data-action="skills-search" value="{{skillsSearch}}" placeholder="Search skills" />
      {{#each indexedSkills as |skill|}}
      <div class="qd31-action-row" data-search-row data-search-text="{{skill.searchText}}"><div><button type="button" class="qd31-reference-button" data-action="open-reference" data-ref-type="skill" data-ref-name="{{skill.name}}" data-ref-page="{{skill.referenceDisplay}}" {{#unless skill.referenceDisplay}}disabled{{/unless}} title="Open skill reference"><strong>{{skill.name}}</strong></button>{{#if skill.relativeLevelDisplay}}<small>{{skill.relativeLevelDisplay}}</small>{{/if}}</div><div>
        <button type="button" class="qd31-square-button" data-action="roll-skill" data-actor-id="{{../activeActor.id}}" data-skill-index="{{skill.index}}">Roll</button>
        <button type="button" class="qd31-square-button" data-action="toggle-pin-skill" data-actor-id="{{../activeActor.id}}" data-skill-key="{{skill.quickSkillKey}}" title="{{#if skill.isPinnedAction}}Remove from Quick Actions{{else}}Pin to Quick Actions{{/if}}">{{#if skill.isPinnedAction}}★{{else}}☆{{/if}}</button>
        {{#if skill.referenceDisplay}}<button type="button" class="qd31-square-button" data-action="open-reference" data-ref-type="skill" data-ref-name="{{skill.name}}" data-ref-page="{{skill.referenceDisplay}}">Ref</button>{{/if}}
      </div></div>
      {{/each}}
    </section>
    <section class="qd31-drawer-body" {{#unless isSpellsDrawerOpen}}hidden{{/unless}}><div class="qd31-action-row"><span>Target</span><button type="button" class="qd31-square-button" data-action="target-action">🎯</button></div><input type="search" data-action="spells-search" value="{{spellsSearch}}" placeholder="Search spells" />
      {{#each indexedSpells as |spell|}}
      <div class="qd31-action-row" data-search-row data-search-text="{{spell.searchText}}"><div><button type="button" class="qd31-reference-button" data-action="open-reference" data-ref-type="spell" data-ref-name="{{spell.name}}" data-ref-page="{{spell.reference}}" {{#unless spell.reference}}disabled{{/unless}} title="Open spell reference"><strong>{{spell.name}}</strong></button>{{#if spell.class}}<small>{{spell.class}}</small>{{/if}}</div><div>
        <button type="button" class="qd31-square-button" data-action="toggle-pin-spell" data-actor-id="{{../activeActor.id}}" data-spell-key="{{spell.spellKey}}" title="{{#if spell.isPinnedAction}}Remove from Quick Actions{{else}}Pin to Quick Actions{{/if}}">{{#if spell.isPinnedAction}}★{{else}}☆{{/if}}</button>
        <button type="button" class="qd31-square-button" data-action="roll-spell" data-actor-id="{{../activeActor.id}}" data-spell-index="{{spell.index}}">Roll</button>
        {{#if spell.reference}}<button type="button" class="qd31-square-button" data-action="open-reference" data-ref-type="spell" data-ref-name="{{spell.name}}" data-ref-page="{{spell.reference}}">Ref</button>{{/if}}
      </div></div>
      {{/each}}
    </section>
    <section class="qd31-drawer-body" {{#unless isSettingsDrawerOpen}}hidden{{/unless}}>
      <div class="qd31-action-row"><span>QuickDeck settings and tools.</span><button type="button" class="qd31-square-button" data-action="open-reference-index">Refs</button></div>
    </section>
  </aside>

  {{#unless isActionsDrawerOpen}}
  <div class="qd31-right-tab-slot">
    <button class="qd31-right-pull-tab" type="button" data-action="toggle-actions-drawer" data-drawer="combat">Actions</button>
  </div>
  {{/unless}}
</section>
