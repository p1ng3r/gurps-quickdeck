<section class="qd30-center-app">
  <header class="qd30-center-header">
    <div>
      <div class="qd30-dev-badge">QD v0.8.3.0 — blank-slate</div>
      <h2>GURPS QuickDeck</h2>
    </div>
    <div class="qd30-toolbar">
      <button type="button" data-action="open-roster-sidecar">Roster</button>
      <button type="button" data-action="open-actions-sidecar" data-drawer="combat">Actions</button>
    </div>
  </header>

  {{#if activeActor}}
  <section class="qd30-actor-card">
    <img src="{{activeActor.img}}" alt="{{activeActor.name}}" />
    <div>
      <h3>{{activeActor.name}}</h3>
      <p>{{activeActor.actorType}}</p>
    </div>
  </section>

  <section class="qd30-command-grid">
    <button type="button" data-action="drop-token" data-actor-id="{{activeActor.id}}">Drop Token</button>
    <button type="button" data-action="open-sheet" data-actor-id="{{activeActor.id}}">Open Sheet</button>
    <button type="button" data-action="open-chat">Chat</button>
    <button type="button" data-action="clear-targets">Targets</button>
    <button type="button" data-action="next-actor">Next</button>
    <button type="button" data-action="repeat-last-attack" {{#unless canRepeatLastAttack}}disabled{{/unless}}>Repeat</button>
  </section>

  <section class="qd30-resource-grid">
    <div class="qd30-resource-card">
      <h4>HP</h4>
      <div>{{gurpsData.display.hp}} / {{gurpsData.display.hpMax}}</div>
      <div class="qd30-toolbar">
        <button type="button" data-action="adjust-resource" data-resource="hp" data-delta="-1">-1</button>
        <input type="number" data-action="set-resource" data-actor-id="{{activeActor.id}}" data-resource="hp" value="{{gurpsData.display.hp}}" />
        <button type="button" data-action="adjust-resource" data-resource="hp" data-delta="1">+1</button>
      </div>
    </div>
    <div class="qd30-resource-card">
      <h4>FP</h4>
      <div>{{gurpsData.display.fp}} / {{gurpsData.display.fpMax}}</div>
      <div class="qd30-toolbar">
        <button type="button" data-action="adjust-resource" data-resource="fp" data-delta="-1">-1</button>
        <input type="number" data-action="set-resource" data-actor-id="{{activeActor.id}}" data-resource="fp" value="{{gurpsData.display.fp}}" />
        <button type="button" data-action="adjust-resource" data-resource="fp" data-delta="1">+1</button>
      </div>
    </div>
    <div class="qd30-resource-card">
      <h4>Move</h4>
      <div>{{gurpsData.display.move}}</div>
    </div>
  </section>

  <section class="qd30-defense-grid">
    <button class="qd30-defense-button" type="button" data-action="roll-defense" data-actor-id="{{activeActor.id}}" data-defense="dodge" data-value="{{gurpsData.display.dodge}}">Dodge {{gurpsData.display.dodge}}</button>
    <button class="qd30-defense-button" type="button" data-action="roll-defense" data-actor-id="{{activeActor.id}}" data-defense="parry" data-value="{{gurpsData.display.parry}}">Parry {{gurpsData.display.parry}}</button>
    <button class="qd30-defense-button" type="button" data-action="roll-defense" data-actor-id="{{activeActor.id}}" data-defense="block" data-value="{{gurpsData.display.block}}">Block {{gurpsData.display.block}}</button>
  </section>
  {{else}}
  <section class="qd30-actor-card">
    <h3>Select a roster actor.</h3>
  </section>
  {{/if}}

  <section class="qd30-pinned-grid">
    <button type="button" disabled>Attack</button>
    <button type="button" disabled>Skill</button>
    <button type="button" disabled>Spell</button>
    <button type="button" disabled>Defend</button>
    <button type="button" disabled>More</button>
  </section>
</section>
