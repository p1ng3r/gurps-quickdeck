<section class="quickdeck-shell">
  <aside class="quickdeck-sidebar">
    <section class="quickdeck-sidebar-block quickdeck-sidebar-roster {{#if isDragOverRoster}}is-drop-active{{/if}}" data-drop-zone="roster">
      <div class="quickdeck-block-title-row">
        <h3>QuickDeck Roster <span class="quickdeck-badge">{{rosterCount}}</span></h3>
        <button
          type="button"
          data-action="clear-roster"
          class="quickdeck-clear-button"
          title="Clear QuickDeck roster"
        >
          Clear Roster
        </button>
      </div>
      <p class="quickdeck-hint">Click selects · Double-click opens sheet · Drag actors here.</p>
      <p class="quickdeck-drop-hint">Drag actors here from the Actor Directory.</p>

      {{#if hasRosterActors}}
        <ul class="quickdeck-roster-list">
          {{#each rosterActors as |actor|}}
            <li>
              <button
                type="button"
                data-action="open-actor"
                data-actor-id="{{actor.id}}"
                class="quickdeck-roster-button {{#if actor.isActive}}is-active{{/if}} {{#if actor.isCurrentTurn}}is-current-turn{{/if}}"
              >
                <img src="{{actor.img}}" alt="{{actor.name}}" />
                <span class="quickdeck-roster-name">{{actor.name}}</span>
                {{#if actor.combatBadge}}
                  <span class="quickdeck-combat-pill">{{actor.combatBadge}}</span>
                {{/if}}
                {{#if actor.actorType}}
                  <span class="quickdeck-type-pill">{{actor.actorType}}</span>
                {{/if}}
              </button>
              <button
                type="button"
                data-action="remove-actor"
                data-actor-id="{{actor.id}}"
                class="quickdeck-remove-button"
                title="Remove from QuickDeck roster"
                aria-label="Remove {{actor.name}} from QuickDeck roster"
              >
                <i class="fas fa-times"></i>
              </button>
            </li>
          {{/each}}
        </ul>
      {{else}}
        <p class="quickdeck-empty">Drag actors here from the Actor Directory or add them below.</p>
      {{/if}}
    </section>

    <section class="quickdeck-sidebar-block quickdeck-sidebar-available">
      <div class="quickdeck-available-header">
        <h4>
          Available Actors
          <span class="quickdeck-badge">
            <span data-count="available-visible">{{visibleAvailableCount}}</span> /
            <span data-count="available-total">{{availableCount}}</span>
          </span>
        </h4>
        <input
          type="search"
          value="{{availableSearch}}"
          data-action="available-search"
          placeholder="Search actors..."
          autocomplete="off"
        />
      </div>

      {{#if hasAvailableActors}}
        <ul class="quickdeck-available-list">
          {{#each availableActors as |actor|}}
            <li data-search-row="available" data-search-text="{{actor.searchText}}">
              <div class="quickdeck-available-actor">
                <img src="{{actor.img}}" alt="{{actor.name}}" />
                <span>{{actor.name}}</span>
                {{#if actor.actorType}}
                  <span class="quickdeck-type-pill">{{actor.actorType}}</span>
                {{/if}}
              </div>
              <button
                type="button"
                data-action="add-actor"
                data-actor-id="{{actor.id}}"
                class="quickdeck-add-button"
                {{#if actor.isInRoster}}disabled{{/if}}
              >
                {{#if actor.isInRoster}}Added{{else}}Add{{/if}}
              </button>
            </li>
          {{/each}}
        </ul>
      {{else}}
        <p class="quickdeck-empty">No available actors found.</p>
      {{/if}}
    </section>
  </aside>

  <main class="quickdeck-main">
    <section class="quickdeck-content">
      <div class="quickdeck-stage" aria-hidden="true"></div>

      <aside class="quickdeck-drawer-stack">
        <nav class="quickdeck-drawer-tabs" aria-label="QuickDeck side drawers">
          <button
            type="button"
            data-action="toggle-drawer"
            data-drawer="combat"
            class="quickdeck-drawer-tab {{#if isCombatDrawerOpen}}is-active{{/if}}"
          >
            Combat Burst
          </button>
          <button
            type="button"
            data-action="toggle-drawer"
            data-drawer="skills"
            class="quickdeck-drawer-tab {{#if isSkillsDrawerOpen}}is-active{{/if}}"
          >
            Skills
          </button>
          <button
            type="button"
            data-action="toggle-drawer"
            data-drawer="quick-skills"
            class="quickdeck-drawer-tab {{#if isQuickSkillsDrawerOpen}}is-active{{/if}}"
          >
            Quick Skills
          </button>
        </nav>

        {{#if activeDrawer}}
          <section class="quickdeck-panel">
            {{#if activeActor}}
              {{#if isCombatDrawerOpen}}
                <div class="quickdeck-panel-content quickdeck-panel-combat">
                  <div class="quickdeck-panel-scroll-root">
                    <header class="quickdeck-actor-header">
                      <img src="{{activeActor.img}}" alt="{{activeActor.name}}" />
                      <div>
                        <h3>{{activeActor.name}}</h3>
                        <p>
                          Combat snapshot
                          {{#if activeActor.actorType}}
                            <span class="quickdeck-type-pill">{{activeActor.actorType}}</span>
                          {{/if}}
                        </p>
                      </div>
                      <button
                        type="button"
                        data-action="open-sheet"
                        data-actor-id="{{activeActor.id}}"
                        class="quickdeck-open-sheet-button"
                      >
                        Open Sheet
                      </button>
                    </header>

                    <dl class="quickdeck-defenses">
                      <div>
                        <dt>Dodge</dt>
                        <dd>{{gurpsData.display.dodge}}</dd>
                        <button
                          type="button"
                          data-action="roll-defense"
                          data-actor-id="{{activeActor.id}}"
                          data-defense="Dodge"
                          data-value="{{gurpsData.display.dodge}}"
                          class="quickdeck-roll-button"
                        >
                          Roll Dodge
                        </button>
                      </div>
                      <div>
                        <dt>Parry</dt>
                        <dd>{{gurpsData.display.parry}}</dd>
                        <button
                          type="button"
                          data-action="roll-defense"
                          data-actor-id="{{activeActor.id}}"
                          data-defense="Parry"
                          data-value="{{gurpsData.display.parry}}"
                          class="quickdeck-roll-button"
                        >
                          Roll Parry
                        </button>
                      </div>
                      <div>
                        <dt>Block</dt>
                        <dd>{{gurpsData.display.block}}</dd>
                        <button
                          type="button"
                          data-action="roll-defense"
                          data-actor-id="{{activeActor.id}}"
                          data-defense="Block"
                          data-value="{{gurpsData.display.block}}"
                          class="quickdeck-roll-button"
                        >
                          Roll Block
                        </button>
                      </div>
                    </dl>

                    <dl class="quickdeck-stats">
                      <div>
                        <dt>HP</dt>
                        <dd>
                          <div class="quickdeck-resource-row">
                            <input
                              type="number"
                              value="{{gurpsData.hp}}"
                              data-action="update-resource"
                              data-actor-id="{{activeActor.id}}"
                              data-resource="hp"
                              aria-label="Edit HP for {{activeActor.name}}"
                            />
                            <span class="quickdeck-resource-max">/ {{gurpsData.display.hpMax}}</span>
                          </div>
                        </dd>
                      </div>
                      <div>
                        <dt>FP</dt>
                        <dd>
                          <div class="quickdeck-resource-row">
                            <input
                              type="number"
                              value="{{gurpsData.fp}}"
                              data-action="update-resource"
                              data-actor-id="{{activeActor.id}}"
                              data-resource="fp"
                              aria-label="Edit FP for {{activeActor.name}}"
                            />
                            <span class="quickdeck-resource-max">/ {{gurpsData.display.fpMax}}</span>
                          </div>
                        </dd>
                      </div>
                      <div>
                        <dt>Move</dt>
                        <dd>{{gurpsData.display.move}}</dd>
                      </div>
                    </dl>
                  </div>

                  <section class="quickdeck-attacks-section">
                    <h4>
                      Attacks (<span data-count="attacks-visible">{{visibleAttackCount}}</span> /
                      <span data-count="attacks-total">{{attackCount}}</span>)
                    </h4>
                    <input
                      type="search"
                      class="quickdeck-drawer-search"
                      value="{{combatSearch}}"
                      data-action="combat-search"
                      placeholder="Search attacks..."
                      autocomplete="off"
                    />

                    {{#if indexedAttacks.length}}
                      <div class="quickdeck-attacks-list">
                        {{#each indexedAttacks as |attack|}}
                          <article class="quickdeck-attack-card" data-search-row="combat" data-search-text="{{attack.searchText}}">
                            <header>
                              <h5>{{attack.name}}</h5>
                              <span>{{attack.type}}</span>
                            </header>
                            <dl>
                              <div>
                                <dt>Level/Skill</dt>
                                <dd>{{#if attack.level}}{{attack.level}}{{else}}—{{/if}}</dd>
                              </div>
                              <div>
                                <dt>Damage</dt>
                                <dd>{{#if attack.damage}}{{attack.damage}}{{else}}—{{/if}}</dd>
                              </div>
                              <div>
                                <dt>Reach/Range</dt>
                                <dd>{{#if attack.reachOrRange}}{{attack.reachOrRange}}{{else}}—{{/if}}</dd>
                              </div>
                              <div>
                                <dt>Parry</dt>
                                <dd>{{#if attack.parry}}{{attack.parry}}{{else}}—{{/if}}</dd>
                              </div>
                              <div>
                                <dt>Block</dt>
                                <dd>{{#if attack.block}}{{attack.block}}{{else}}—{{/if}}</dd>
                              </div>
                            </dl>
                            <button
                              type="button"
                              data-action="roll-attack"
                              data-actor-id="{{../activeActor.id}}"
                              data-attack-index="{{attack.index}}"
                              class="quickdeck-roll-button"
                            >
                              Roll Attack
                            </button>
                          </article>
                        {{/each}}
                      </div>
                    {{else}}
                      <p class="quickdeck-empty">No attacks match this search.</p>
                    {{/if}}
                  </section>
                </div>
              {{/if}}

              {{#if isSkillsDrawerOpen}}
                <div class="quickdeck-panel-content quickdeck-panel-skills">
                  <header class="quickdeck-actor-header">
                    <img src="{{activeActor.img}}" alt="{{activeActor.name}}" />
                    <div>
                      <h3>{{activeActor.name}}</h3>
                      <p>
                        Skills snapshot
                        {{#if activeActor.actorType}}
                          <span class="quickdeck-type-pill">{{activeActor.actorType}}</span>
                        {{/if}}
                      </p>
                    </div>
                    <button
                      type="button"
                      data-action="open-sheet"
                      data-actor-id="{{activeActor.id}}"
                      class="quickdeck-open-sheet-button"
                    >
                      Open Sheet
                    </button>
                  </header>

                  <section class="quickdeck-skills-section">
                    <h4>
                      Skills (<span data-count="skills-visible">{{visibleSkillsCount}}</span> /
                      <span data-count="skills-total">{{skillsCount}}</span>)
                    </h4>
                    <input
                      type="search"
                      class="quickdeck-drawer-search"
                      value="{{skillsSearch}}"
                      data-action="skills-search"
                      placeholder="Search skills..."
                      autocomplete="off"
                    />

                    {{#if indexedSkills.length}}
                      <div class="quickdeck-skills-list">
                        {{#each indexedSkills as |skill|}}
                          <article class="quickdeck-skill-row {{#if skill.isQuickSkillSelected}}is-quick-skill-selected{{/if}}" data-search-row="skills" data-search-text="{{skill.searchText}}">
                            <label class="quickdeck-skill-checkbox" aria-label="Mark {{skill.name}} as Quick Skill">
                              <input
                                type="checkbox"
                                data-action="toggle-quick-skill"
                                data-actor-id="{{../activeActor.id}}"
                                data-skill-key="{{skill.quickSkillKey}}"
                                {{#if skill.isQuickSkillSelected}}checked{{/if}}
                              />
                            </label>
                            <div class="quickdeck-skill-main">
                              <h5>{{skill.name}}</h5>
                              <p>Level {{#if skill.level}}{{skill.level}}{{else}}—{{/if}}</p>
                            </div>
                            <button
                              type="button"
                              data-action="roll-skill"
                              data-actor-id="{{../activeActor.id}}"
                              data-skill-index="{{skill.index}}"
                              class="quickdeck-roll-button"
                            >
                              Roll Skill
                            </button>
                          </article>
                        {{/each}}
                      </div>
                    {{else}}
                      <p class="quickdeck-empty">No skills match this search.</p>
                    {{/if}}
                  </section>
                </div>
              {{/if}}

              {{#if isQuickSkillsDrawerOpen}}
                <div class="quickdeck-panel-content quickdeck-panel-skills">
                  <header class="quickdeck-actor-header">
                    <img src="{{activeActor.img}}" alt="{{activeActor.name}}" />
                    <div>
                      <h3>{{activeActor.name}}</h3>
                      <p>
                        Quick Skills
                        {{#if activeActor.actorType}}
                          <span class="quickdeck-type-pill">{{activeActor.actorType}}</span>
                        {{/if}}
                      </p>
                    </div>
                    <button
                      type="button"
                      data-action="open-sheet"
                      data-actor-id="{{activeActor.id}}"
                      class="quickdeck-open-sheet-button"
                    >
                      Open Sheet
                    </button>
                  </header>

                  <section class="quickdeck-skills-section">
                    <h4>
                      Quick Skills (<span data-count="quick-skills-visible">{{visibleQuickSkillsCount}}</span> /
                      <span data-count="quick-skills-total">{{quickSkillsCount}}</span>)
                    </h4>
                    <input
                      type="search"
                      class="quickdeck-drawer-search"
                      value="{{quickSkillsSearch}}"
                      data-action="quick-skills-search"
                      placeholder="Search quick skills..."
                      autocomplete="off"
                    />

                    {{#if indexedQuickSkills.length}}
                      <div class="quickdeck-skills-list">
                        {{#each indexedQuickSkills as |skill|}}
                          <article class="quickdeck-skill-row {{#if skill.isQuickSkillSelected}}is-quick-skill-selected{{/if}}" data-search-row="quick-skills" data-search-text="{{skill.searchText}}">
                            <label class="quickdeck-skill-checkbox" aria-label="Mark {{skill.name}} as Quick Skill">
                              <input
                                type="checkbox"
                                data-action="toggle-quick-skill"
                                data-actor-id="{{../activeActor.id}}"
                                data-skill-key="{{skill.quickSkillKey}}"
                                {{#if skill.isQuickSkillSelected}}checked{{/if}}
                              />
                            </label>
                            <div class="quickdeck-skill-main">
                              <h5>{{skill.name}}</h5>
                              <p>Level {{#if skill.level}}{{skill.level}}{{else}}—{{/if}}</p>
                            </div>
                            <button
                              type="button"
                              data-action="roll-skill"
                              data-actor-id="{{../activeActor.id}}"
                              data-skill-index="{{skill.index}}"
                              class="quickdeck-roll-button"
                            >
                              Roll Skill
                            </button>
                          </article>
                        {{/each}}
                      </div>
                    {{else}}
                      <p class="quickdeck-empty">Check skills in the Skills drawer to pin them here.</p>
                    {{/if}}
                  </section>
                </div>
              {{/if}}
            {{else}}
              <div class="quickdeck-panel-content">
                <p class="quickdeck-empty">Select a roster actor to open a drawer.</p>
              </div>
            {{/if}}
          </section>
        {{/if}}
      </aside>
    </section>
    <footer class="quickdeck-footer-hint">Click selects · Double-click opens sheet · Drag actors here.</footer>
  </main>
</section>
