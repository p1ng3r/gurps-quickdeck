<section class="qd8-shell {{#if isLeftPanelCollapsed}}is-left-collapsed{{/if}} {{#if isRightPanelCollapsed}}is-right-collapsed{{/if}}">
  <header class="qd8-header">
    <div class="qd8-title">GURPS QuickDeck</div>
    <div class="qd8-dev-badge">QD v0.8.1.2 — clean-shell</div>
    <div class="qd8-command-plaque">Command Desk</div>
  </header>

  <div class="qd8-grid">
    <aside class="qd8-left">
      {{#if isLeftPanelOpen}}
        <div class="qd8-left-open">
          <div class="qd8-icon-spine">
            <button type="button" class="qd8-spine-btn" data-action="close-left-panel" aria-label="Collapse left roster panel">«</button>
            <button type="button" class="qd8-spine-btn" data-action="open-left-panel">R</button>
            <button type="button" class="qd8-spine-btn" data-action="open-left-panel">A</button>
          </div>
          <div class="qd8-left-panels">
            <section class="qd8-panel qd8-roster {{#if isDragOverRoster}}is-drop-active{{/if}}" data-drop-zone="roster">
              <div class="qd8-panel-header"><h3>QuickDeck Roster <span class="quickdeck-badge">{{rosterCount}}</span></h3><button type="button" data-action="clear-roster">Clear</button></div>
              {{#if hasRosterActors}}<ul class="quickdeck-roster-list">{{#each rosterActors as |actor|}}<li><button type="button" data-action="open-actor" data-actor-id="{{actor.id}}" class="quickdeck-roster-button {{#if actor.isActive}}is-active{{/if}}"><img src="{{actor.img}}" alt="{{actor.name}}" /><span class="quickdeck-roster-name">{{actor.name}}</span></button><button type="button" data-action="remove-actor" data-actor-id="{{actor.id}}" class="quickdeck-remove-button">×</button></li>{{/each}}</ul>{{else}}<p class="quickdeck-empty">No actors in roster.</p>{{/if}}
            </section>
            <section class="qd8-panel qd8-available">
              <div class="qd8-panel-header"><h3>Available Actors <span class="quickdeck-badge"><span data-count="available-visible">{{visibleAvailableCount}}</span> / <span data-count="available-total">{{availableCount}}</span></span></h3></div>
              <input type="search" value="{{availableSearch}}" data-action="available-search" placeholder="Search actors..." autocomplete="off" />
              {{#if hasAvailableActors}}<ul class="quickdeck-available-list">{{#each availableActors as |actor|}}<li data-search-row="available" data-search-text="{{actor.searchText}}"><span class="quickdeck-available-actor"><img src="{{actor.img}}" alt="{{actor.name}}" /><span>{{actor.name}}</span></span><button type="button" data-action="add-actor" data-actor-id="{{actor.id}}" class="quickdeck-add-button" {{#if actor.isInRoster}}disabled{{/if}}>{{#if actor.isInRoster}}Added{{else}}Add{{/if}}</button></li>{{/each}}</ul>{{else}}<p class="quickdeck-empty">No actors found.</p>{{/if}}
            </section>
          </div>
        </div>
      {{else}}
        <div class="qd8-left-rail">
          <button type="button" data-action="open-left-panel" aria-label="Open left roster panel">»</button>
          <button type="button" data-action="open-left-panel">Roster</button>
          <button type="button" data-action="open-left-panel">Actors</button>
          <span>•</span><span>•</span><span>•</span>
        </div>
      {{/if}}
    </aside>

    <main class="qd8-center">
      <section class="qd8-panel qd8-cockpit">
        {{#if activeActor}}
          <header class="quickdeck-actor-header"><img src="{{activeActor.img}}" alt="{{activeActor.name}}" /><div class="quickdeck-actor-identity"><h3>{{activeActor.name}}</h3></div><div><button type="button" data-action="drop-token" data-actor-id="{{activeActor.id}}">Drop Token</button><button type="button" data-action="open-sheet" data-actor-id="{{activeActor.id}}">Open Sheet</button></div></header>
          <div class="quickdeck-combat-flow-controls"><button type="button" data-action="open-chat">Chat</button><button type="button" data-action="clear-targets">Targets</button><button type="button" data-action="next-actor">Next</button><button type="button" data-action="repeat-last-attack" {{#unless canRepeatLastAttack}}disabled{{/unless}}>Repeat</button></div>
          <div class="quickdeck-stats"><div><label>HP</label><input type="text" data-action="set-resource" data-actor-id="{{activeActor.id}}" data-resource="HP" value="{{gurpsData.display.hp}}" /><button type="button" data-action="adjust-resource" data-actor-id="{{activeActor.id}}" data-resource="HP" data-delta="-1">-</button><button type="button" data-action="adjust-resource" data-actor-id="{{activeActor.id}}" data-resource="HP" data-delta="1">+</button></div><div><label>FP</label><input type="text" data-action="set-resource" data-actor-id="{{activeActor.id}}" data-resource="FP" value="{{gurpsData.display.fp}}" /><button type="button" data-action="adjust-resource" data-actor-id="{{activeActor.id}}" data-resource="FP" data-delta="-1">-</button><button type="button" data-action="adjust-resource" data-actor-id="{{activeActor.id}}" data-resource="FP" data-delta="1">+</button></div><div><label>Move</label><span>{{gurpsData.display.move}}</span></div></div>
          <div class="quickdeck-defense-grid"><button type="button" data-action="roll-defense" data-actor-id="{{activeActor.id}}" data-defense="Dodge" data-value="{{gurpsData.display.dodge}}">Dodge {{gurpsData.display.dodge}}</button><button type="button" data-action="roll-defense" data-actor-id="{{activeActor.id}}" data-defense="Parry" data-value="{{gurpsData.display.parry}}">Parry {{gurpsData.display.parry}}</button><button type="button" data-action="roll-defense" data-actor-id="{{activeActor.id}}" data-defense="Block" data-value="{{gurpsData.display.block}}">Block {{gurpsData.display.block}}</button></div>
          <div class="qd8-quick-actions-strip"><span>Quick Actions</span><button type="button" disabled>1</button><button type="button" disabled>2</button><button type="button" disabled>3</button><button type="button" disabled>4</button><button type="button" disabled>5</button></div>
        {{else}}<p class="quickdeck-empty">Select an actor to open the cockpit.</p>{{/if}}
      </section>
    </main>

    <aside class="qd8-right">
      {{#if isRightPanelOpen}}
      <section class="qd8-right-open qd8-panel">
        <header class="qd8-panel-header"><div class="qd8-drawer-tabs"><button type="button" data-action="toggle-drawer" data-drawer="combat" class="{{#if isCombatDrawerOpen}}is-active{{/if}}">Combat</button><button type="button" data-action="toggle-drawer" data-drawer="skills" class="{{#if isSkillsDrawerOpen}}is-active{{/if}}">Skills</button><button type="button" data-action="toggle-drawer" data-drawer="spells" class="{{#if isSpellsDrawerOpen}}is-active{{/if}}">Spells</button><button type="button" data-action="toggle-drawer" data-drawer="settings" class="{{#if isSettingsDrawerOpen}}is-active{{/if}}">Settings</button></div><button type="button" data-action="close-right-panel" aria-label="Collapse right drawer">»</button></header>
        <div class="qd8-drawer-body">
        {{#if isCombatDrawerOpen}}<input type="search" value="{{combatSearch}}" data-action="combat-search" placeholder="Search attacks..." />{{#each indexedAttacks as |attack|}}<div data-search-row="combat" data-search-text="{{attack.searchText}}"><button type="button" data-action="toggle-favorite-attack" data-actor-id="{{../activeActor.id}}" data-attack-key="{{attack.attackKey}}">★</button><button type="button" data-action="roll-attack" data-actor-id="{{../activeActor.id}}" data-attack-index="{{attack.index}}">{{attack.name}}</button><button type="button" data-action="roll-damage" data-actor-id="{{../activeActor.id}}" data-attack-index="{{attack.index}}">Dmg</button></div>{{/each}}{{/if}}
        {{#if isSkillsDrawerOpen}}<input type="search" value="{{skillsSearch}}" data-action="skills-search" placeholder="Search skills..." /><input type="search" value="{{quickSkillsSearch}}" data-action="quick-skills-search" placeholder="Search quick skills..." />{{#each indexedSkills as |skill|}}<div data-search-row="skills" data-search-text="{{skill.searchText}}"><input type="checkbox" data-action="toggle-quick-skill" data-actor-id="{{../activeActor.id}}" data-skill-key="{{skill.quickSkillKey}}" {{#if skill.isQuickSkillSelected}}checked{{/if}} /><button type="button" data-action="roll-skill" data-actor-id="{{../activeActor.id}}" data-skill-index="{{skill.index}}">{{skill.name}}</button>{{#if skill.isQuickSkillSelected}}<button type="button" data-action="unpin-quick-skill" data-actor-id="{{../activeActor.id}}" data-skill-key="{{skill.quickSkillKey}}">Unpin</button>{{/if}}</div>{{/each}}{{/if}}
        {{#if isSpellsDrawerOpen}}<input type="search" value="{{spellsSearch}}" data-action="spells-search" placeholder="Search spells..." />{{#each indexedSpells as |spell|}}<div data-search-row="spells" data-search-text="{{spell.searchText}}"><button type="button" data-action="toggle-favorite-spell" data-actor-id="{{../activeActor.id}}" data-spell-key="{{spell.spellKey}}">★</button><button type="button" data-action="roll-spell" data-actor-id="{{../activeActor.id}}" data-spell-index="{{spell.index}}">{{spell.name}}</button><button type="button" data-action="open-reference" data-ref-type="spell" data-ref-name="{{spell.name}}" data-ref-page="{{spell.pageHint}}" data-ref-source="{{spell.reference}}">Ref</button></div>{{/each}}{{/if}}
        {{#if isSettingsDrawerOpen}}<p>Settings placeholder.</p><button type="button" data-action="open-reference-index">Local Overrides</button>{{/if}}
        </div>
      </section>
      {{else}}
      <div class="qd8-right-rail">
        <button type="button" data-action="open-right-drawer" data-drawer="combat" aria-label="Open Combat drawer">Combat</button>
        <button type="button" data-action="open-right-drawer" data-drawer="skills" aria-label="Open Skills drawer">Skills</button>
        <button type="button" data-action="open-right-drawer" data-drawer="spells" aria-label="Open Spells drawer">Spells</button>
        <button type="button" data-action="open-right-drawer" data-drawer="settings" aria-label="Open Settings drawer">Settings</button>
      </div>
      {{/if}}
    </aside>
  </div>
</section>
