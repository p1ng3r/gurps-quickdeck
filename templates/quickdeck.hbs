<section class="qd22-center-shell">
  <header class="qd18-header">
    <div class="quickdeck-dev-badge qd18-dev-badge" aria-hidden="true">QD v0.8.2.2 — real-sidecars</div>
    <div class="qd22-sidecar-buttons">
      <button type="button" data-action="open-roster-sidecar">Roster</button>
      <button type="button" data-action="open-actions-sidecar" data-drawer="combat">Actions</button>
    </div>
  </header>

  <main class="qd18-center">
    {{#if activeActor}}
    <section class="quickdeck-selected-cockpit" aria-label="Selected actor cockpit">
      <header class="quickdeck-actor-header">
        <img src="{{activeActor.img}}" alt="{{activeActor.name}}" />
        <div class="quickdeck-actor-identity"><h3>{{activeActor.name}}</h3><p>{{activeActor.actorType}}</p></div>
        <div class="quickdeck-actor-header-actions">
          <button type="button" data-action="drop-token" data-actor-id="{{activeActor.id}}">Drop Token</button>
          <button type="button" data-action="open-sheet" data-actor-id="{{activeActor.id}}">Open Sheet</button>
        </div>
      </header>
      <div class="quickdeck-combat-flow-controls">
        <button type="button" data-action="open-chat">Chat</button>
        <button type="button" data-action="clear-targets">Targets</button>
        <button type="button" data-action="next-actor">Next</button>
        <button type="button" data-action="repeat-last-attack" {{#unless canRepeatLastAttack}}disabled{{/unless}}>Repeat</button>
      </div>
      <div>HP {{gurpsData.display.hp}} / {{gurpsData.display.hpMax}} · FP {{gurpsData.display.fp}} / {{gurpsData.display.fpMax}} · Move {{gurpsData.display.move}}</div>
      <div class="quickdeck-defense-buttons">
        <button type="button" data-action="roll-defense" data-actor-id="{{activeActor.id}}" data-defense="Dodge" data-value="{{gurpsData.display.dodge}}">Dodge {{gurpsData.display.dodge}}</button>
        <button type="button" data-action="roll-defense" data-actor-id="{{activeActor.id}}" data-defense="Parry" data-value="{{gurpsData.display.parry}}">Parry {{gurpsData.display.parry}}</button>
        <button type="button" data-action="roll-defense" data-actor-id="{{activeActor.id}}" data-defense="Block" data-value="{{gurpsData.display.block}}">Block {{gurpsData.display.block}}</button>
      </div>
      <div class="qd18-pinned-actions"><button disabled>1</button><button disabled>2</button><button disabled>3</button><button disabled>4</button><button disabled>5</button></div>
    </section>
    {{else}}<section class="quickdeck-selected-cockpit quickdeck-selected-cockpit-empty"><h3>Select a roster actor.</h3></section>{{/if}}
  </main>
</section>
