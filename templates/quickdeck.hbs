<section class="qd30-center-app">
  <header class="qd30-center-header">
    <div>
      <div class="quickdeck-dev-badge">QD v0.8.3.1 — canvas-fit</div>
      <h2>QuickDeck Cockpit</h2>
    </div>
    <div class="qd30-toolbar">
      <button type="button" data-action="open-roster-sidecar">Roster</button>
      <button type="button" data-action="open-actions-sidecar" data-drawer="combat">Actions</button>
    </div>
  </header>
  <main>
    {{#if activeActor}}
    <section class="qd30-actor-card" aria-label="Selected actor cockpit">
      <header class="quickdeck-actor-header">
        <img src="{{activeActor.img}}" alt="{{activeActor.name}}" />
        <div class="quickdeck-actor-identity"><h3>{{activeActor.name}}</h3><p>{{activeActor.actorType}}</p></div>
        <div class="quickdeck-actor-header-actions">
          <button type="button" data-action="drop-token" data-actor-id="{{activeActor.id}}">Drop Token</button>
          <button type="button" data-action="open-sheet" data-actor-id="{{activeActor.id}}">Open Sheet</button>
        </div>
      </header>
      <div class="qd30-command-grid">
        <button type="button" data-action="open-chat">Chat</button><button type="button" data-action="clear-targets">Targets</button><button type="button" data-action="next-actor">Next</button><button type="button" data-action="repeat-last-attack" {{#unless canRepeatLastAttack}}disabled{{/unless}}>Repeat</button>
      </div>
      <div class="qd30-resource-grid">
        <article class="qd30-resource-card">
          <div class="qd30-resource-icon" aria-hidden="true">♥</div><div><strong>HP</strong><div>{{gurpsData.display.hp}} / {{gurpsData.display.hpMax}}</div></div>
          <div class="qd30-resource-bar"><span style="width: {{gurpsData.display.hpPct}}%;"></span></div>
          <div class="qd30-resource-controls"><button class="qd30-square-button" type="button" data-action="adjust-resource" data-actor-id="{{activeActor.id}}" data-resource="HP" data-delta="-1">−</button><input type="number" data-action="set-resource" data-actor-id="{{activeActor.id}}" data-resource="HP" value="{{gurpsData.display.hp}}" /><button class="qd30-square-button" type="button" data-action="adjust-resource" data-actor-id="{{activeActor.id}}" data-resource="HP" data-delta="1">+</button></div>
        </article>
        <article class="qd30-resource-card">
          <div class="qd30-resource-icon" aria-hidden="true">⚡</div><div><strong>FP</strong><div>{{gurpsData.display.fp}} / {{gurpsData.display.fpMax}}</div></div>
          <div class="qd30-resource-bar"><span style="width: {{gurpsData.display.fpPct}}%;"></span></div>
          <div class="qd30-resource-controls"><button class="qd30-square-button" type="button" data-action="adjust-resource" data-actor-id="{{activeActor.id}}" data-resource="FP" data-delta="-1">−</button><input type="number" data-action="set-resource" data-actor-id="{{activeActor.id}}" data-resource="FP" value="{{gurpsData.display.fp}}" /><button class="qd30-square-button" type="button" data-action="adjust-resource" data-actor-id="{{activeActor.id}}" data-resource="FP" data-delta="1">+</button></div>
        </article>
        <article class="qd30-resource-card"><div class="qd30-resource-icon">➤</div><div><strong>Move</strong><div>{{gurpsData.display.move}}</div></div></article>
      </div>
      <div class="qd30-defense-grid">
        <button class="qd30-defense-button" type="button" data-action="roll-defense" data-actor-id="{{activeActor.id}}" data-defense="Dodge" data-value="{{gurpsData.display.dodge}}">Dodge {{gurpsData.display.dodge}}</button>
        <button class="qd30-defense-button" type="button" data-action="roll-defense" data-actor-id="{{activeActor.id}}" data-defense="Parry" data-value="{{gurpsData.display.parry}}">Parry {{gurpsData.display.parry}}</button>
        <button class="qd30-defense-button" type="button" data-action="roll-defense" data-actor-id="{{activeActor.id}}" data-defense="Block" data-value="{{gurpsData.display.block}}">Block {{gurpsData.display.block}}</button>
      </div>
      <div class="qd30-pinned-grid"><button disabled>1</button><button disabled>2</button><button disabled>3</button><button disabled>4</button><button disabled>5</button></div>
    </section>
    {{else}}<section class="qd30-actor-card"><h3>Select a roster actor.</h3></section>{{/if}}
  </main>
</section>
