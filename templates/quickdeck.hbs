<section class="quickdeck-shell">
  <aside class="quickdeck-sidebar">
    <h3>Characters</h3>

    {{#if hasCharacters}}
      <ul class="quickdeck-character-list">
        {{#each characters as |actor|}}
          <li>
            <button
              type="button"
              data-action="open-actor"
              data-actor-id="{{actor.id}}"
              class="quickdeck-character-button {{#if actor.isActive}}is-active{{/if}}"
            >
              <img src="{{actor.img}}" alt="{{actor.name}}" />
              <span>{{actor.name}}</span>
            </button>
          </li>
        {{/each}}
      </ul>
    {{else}}
      <p class="quickdeck-empty">No character actors found.</p>
    {{/if}}
  </aside>

  <main class="quickdeck-main">
    <nav class="quickdeck-tabs" aria-label="Open character tabs">
      {{#each tabs as |tab|}}
        <button
          type="button"
          data-action="activate-tab"
          data-actor-id="{{tab.id}}"
          class="quickdeck-tab {{#if tab.isActive}}is-active{{/if}}"
        >
          <img src="{{tab.img}}" alt="{{tab.name}}" />
          <span>{{tab.name}}</span>
        </button>
      {{/each}}
    </nav>

    <section class="quickdeck-panel">
      {{#if activeActor}}
        <header class="quickdeck-actor-header">
          <img src="{{activeActor.img}}" alt="{{activeActor.name}}" />
          <div>
            <h2>{{activeActor.name}}</h2>
            <p>Lightweight QuickDeck viewer MVP</p>
          </div>
        </header>

        <dl class="quickdeck-stats">
          <div>
            <dt>HP</dt>
            <dd>{{#if gurpsData.hp}}{{gurpsData.hp}}{{else}}—{{/if}}</dd>
          </div>
          <div>
            <dt>FP</dt>
            <dd>{{#if gurpsData.fp}}{{gurpsData.fp}}{{else}}—{{/if}}</dd>
          </div>
          <div>
            <dt>Move</dt>
            <dd>{{#if gurpsData.move}}{{gurpsData.move}}{{else}}—{{/if}}</dd>
          </div>
          <div>
            <dt>Dodge</dt>
            <dd>{{#if gurpsData.dodge}}{{gurpsData.dodge}}{{else}}—{{/if}}</dd>
          </div>
        </dl>

        <section class="quickdeck-attacks-section">
          <h3>Attacks</h3>

          {{#if gurpsData.attacks.length}}
            <div class="quickdeck-attacks-list">
              {{#each gurpsData.attacks as |attack|}}
                <article class="quickdeck-attack-card">
                  <header>
                    <h4>{{attack.name}}</h4>
                    <span>{{attack.type}}</span>
                  </header>
                  <dl>
                    <div>
                      <dt>Level/Skill</dt>
                      <dd>{{#if attack.level}}{{attack.level}}{{else}}—{{/if}}</dd>
                    </div>
                    <div>
                      <dt>Damage</dt>
                      <dd>{{#if attack.damage}}{{attack.damage}}{{else}}—{{/if}}</dd>
                    </div>
                    <div>
                      <dt>Reach/Range</dt>
                      <dd>{{#if attack.reachOrRange}}{{attack.reachOrRange}}{{else}}—{{/if}}</dd>
                    </div>
                    <div>
                      <dt>Parry/Block</dt>
                      <dd>{{#if attack.parryOrBlock}}{{attack.parryOrBlock}}{{else}}—{{/if}}</dd>
                    </div>
                  </dl>
                </article>
              {{/each}}
            </div>
          {{else}}
            <p class="quickdeck-empty">No attacks found for this character.</p>
          {{/if}}
        </section>
      {{else}}
        <p class="quickdeck-empty">Open a character from the left to start.</p>
      {{/if}}
    </section>
  </main>
</section>
