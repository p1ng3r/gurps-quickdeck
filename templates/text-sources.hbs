<section class="quickdeck-pdf-sources-shell">
  <header class="quickdeck-reference-panel quickdeck-pdf-sources-header">
    <h2>QuickDeck Text Sources</h2>
    <p>Create named text sources, paste local text, and build Reference Index skill entries from it.</p>
    <p class="quickdeck-reference-warning">{{warningText}}</p>
  </header>

  <section class="quickdeck-reference-panel quickdeck-pdf-sources-body">
    <div class="quickdeck-text-source-toolbar">
      <button type="button" class="quickdeck-add-button" data-action="add-default-source">
        Add "{{defaultSourceName}}"
      </button>
    </div>

    {{#if hasSources}}
      <ol class="quickdeck-pdf-sources-list">
        {{#each sources as |source|}}
          <li class="quickdeck-pdf-source-row" data-source-row data-index="{{source.index}}" data-source-id="{{source.id}}" data-created-at="{{source.createdAt}}">
            <div class="quickdeck-pdf-source-grid quickdeck-text-source-grid">
              <label>
                <span>Display name</span>
                <input type="text" data-field="displayName" value="{{source.displayName}}" placeholder="Dungeon Fantasy Adventurers Skills" />
              </label>
              <label>
                <span>Book key / ID</span>
                <input type="text" data-field="bookKey" value="{{source.bookKey}}" placeholder="dungeon-fantasy-adventurers" />
              </label>
              <label class="quickdeck-text-source-textarea">
                <span>Pasted text (local only)</span>
                <textarea data-field="rawText" rows="12" placeholder="Paste source text here...">{{source.rawText}}</textarea>
              </label>
            </div>
            <div class="quickdeck-text-source-row-actions">
              <button type="button" class="quickdeck-roll-button" data-action="build-index-from-text-source" data-source-id="{{source.id}}">
                Build Index from Text Source
              </button>
              <button type="button" class="quickdeck-remove-button" data-action="remove-source" data-index="{{source.index}}">
                Remove
              </button>
            </div>
          </li>
        {{/each}}
      </ol>
    {{else}}
      <p class="quickdeck-reference-empty"><em>No text sources configured yet. Add one to get started.</em></p>
    {{/if}}

    <footer class="quickdeck-pdf-sources-actions">
      <button type="button" class="quickdeck-add-button" data-action="add-source">Add Source</button>
      <button type="button" class="quickdeck-roll-button" data-action="save-sources">Save Sources</button>
    </footer>

    {{#if hasReviewRows}}
      <section class="quickdeck-reference-index-import quickdeck-text-source-review">
        <h3>Review Parsed Entries</h3>
        <p>Select rows to upsert into Reference Index (name + type).</p>
        <div class="quickdeck-reference-index-tool-actions">
          <button type="button" class="quickdeck-reference-index-button" data-action="toggle-review-all" data-select="all">Select All</button>
          <button type="button" class="quickdeck-reference-index-button" data-action="toggle-review-all" data-select="none">Select None</button>
        </div>
        <table class="quickdeck-text-review-table">
          <thead>
            <tr>
              <th>Select</th>
              <th>Name</th>
              <th>Type</th>
              <th>Book Key</th>
              <th>Confidence</th>
            </tr>
          </thead>
          <tbody>
            {{#each reviewRows as |row|}}
              <tr>
                <td><input type="checkbox" data-review-select data-row-id="{{row.id}}" {{#if row.selected}}checked{{/if}} /></td>
                <td>{{row.name}}</td>
                <td>{{row.type}}</td>
                <td>{{row.bookKey}}</td>
                <td>{{row.confidence}}</td>
              </tr>
            {{/each}}
          </tbody>
        </table>
        <div class="quickdeck-reference-index-tool-actions">
          <button type="button" class="quickdeck-roll-button" data-action="save-selected-review-rows">Save Selected to Reference Index</button>
        </div>
      </section>
    {{/if}}
  </section>
</section>
