<section class="quickdeck-pdf-sources-shell quickdeck-reference-index-shell">
  <header class="quickdeck-reference-panel quickdeck-pdf-sources-header">
    <h2>QuickDeck Local Overrides</h2>
    <p>Store optional local override metadata for skills, spells, and rules. Bundled repo summaries remain the default reference content.</p>
  </header>

  <section class="quickdeck-reference-panel quickdeck-pdf-sources-body">
    <section class="quickdeck-reference-index-tools">
      <label class="quickdeck-reference-index-search-label">
        <span>Search metadata</span>
        <input type="search" data-reference-index-search placeholder="Search name, type, source key, page, or notes" autocomplete="off" />
      </label>
      <div class="quickdeck-reference-index-tool-actions">
        <button type="button" class="quickdeck-reference-index-button" data-action="export-reference-index-json">Export JSON (Copy)</button>
      </div>
    </section>

    {{#if hasEntries}}
      <ol class="quickdeck-pdf-sources-list quickdeck-reference-index-list">
        {{#each entries as |entry|}}
          <li class="quickdeck-pdf-source-row quickdeck-reference-index-row {{#if entry.focusRow}}is-focus-row{{/if}}" data-reference-index-row data-index="{{entry.index}}">
            <div class="quickdeck-pdf-source-grid quickdeck-reference-index-grid">
              <label>
                <span>Name</span>
                <input type="text" data-field="name" value="{{entry.name}}" placeholder="Lockpicking" />
              </label>
              <label>
                <span>Type</span>
                <select data-field="type">
                  {{#each entry.typeOptions as |typeOption|}}
                    <option value="{{typeOption.value}}" {{#if typeOption.selected}}selected{{/if}}>{{typeOption.label}}</option>
                  {{/each}}
                </select>
              </label>
              <label>
                <span>Source / book key</span>
                <input type="text" data-field="bookKey" value="{{entry.bookKey}}" placeholder="basic-campaigns" />
              </label>
              <label>
                <span>Displayed page</span>
                <input type="number" data-field="displayedPage" value="{{entry.displayedPage}}" min="1" step="1" placeholder="344" />
              </label>
              <label class="quickdeck-pdf-source-notes">
                <span>Notes</span>
                <textarea data-field="notes" rows="2" placeholder="Optional personal note">{{entry.notes}}</textarea>
              </label>
            </div>
            <button type="button" class="quickdeck-remove-button" data-action="remove-reference-index-entry" data-index="{{entry.index}}">
              Remove
            </button>
          </li>
        {{/each}}
      </ol>
      <p class="quickdeck-reference-empty" data-reference-filter-empty hidden><em>No entries match the current search.</em></p>
    {{else}}
      <p class="quickdeck-reference-empty"><em>No local overrides yet. Add one to override source/page metadata.</em></p>
    {{/if}}

    <section class="quickdeck-reference-index-import">
      <h3>Import JSON metadata</h3>
      <p class="quickdeck-reference-warning">Only import metadata you created. Do not paste copyrighted rulebook text.</p>
      <textarea data-reference-index-import-json rows="5" placeholder='[{"name":"Lockpicking","type":"skill","bookKey":"basic-campaigns","displayedPage":"206","notes":""}]'></textarea>
      <div class="quickdeck-reference-index-tool-actions">
        <button type="button" class="quickdeck-reference-index-button" data-action="import-reference-index-merge">Import Merge</button>
        <button type="button" class="quickdeck-reference-index-button" data-action="import-reference-index-replace">Import Replace</button>
      </div>
    </section>

    <footer class="quickdeck-pdf-sources-actions">
      <button type="button" class="quickdeck-add-button" data-action="add-reference-index-entry">Add Entry</button>
      <button type="button" class="quickdeck-roll-button" data-action="save-reference-index">Save Overrides</button>
    </footer>
  </section>
</section>
