<section class="qd30-sidecar">
<header class="qd30-sidecar-header"><h3>QuickDeck Actions</h3><button class="qd30-square-button" type="button" data-action="close-actions-sidecar">✕</button></header>
<nav class="qd30-actions-tabs">
<button type="button" data-action="toggle-drawer" data-drawer="combat">Combat</button><button type="button" data-action="toggle-drawer" data-drawer="skills">Skills</button><button type="button" data-action="toggle-drawer" data-drawer="spells">Spells</button><button type="button" data-action="toggle-drawer" data-drawer="settings">Settings</button>
</nav>
{{#if isCombatDrawerOpen}}<input class="qd30-search" type="search" value="{{combatSearch}}" data-action="combat-search" placeholder="Search attacks" />
{{#each indexedAttacks as |attack|}}<div class="qd30-action-row" data-search-row="combat" data-search-text="{{attack.searchText}}"><div><strong>{{attack.name}}</strong><small>{{attack.type}}</small></div><div><button data-action="toggle-favorite-attack" data-actor-id="{{../activeActor.id}}" data-attack-key="{{attack.attackKey}}">★</button><button data-action="roll-attack" data-actor-id="{{../activeActor.id}}" data-attack-index="{{attack.index}}">Attack</button><button data-action="roll-damage" data-actor-id="{{../activeActor.id}}" data-attack-index="{{attack.index}}">Dmg</button></div></div>{{/each}}{{/if}}
{{#if isSkillsDrawerOpen}}<input class="qd30-search" type="search" value="{{skillsSearch}}" data-action="skills-search" placeholder="Search skills" />{{#each indexedSkills as |skill|}}<div class="qd30-action-row" data-search-row="skills" data-search-text="{{skill.searchText}}"><div><strong>{{skill.name}}</strong></div><div><button data-action="roll-skill" data-actor-id="{{../activeActor.id}}" data-skill-index="{{skill.index}}">Roll</button><button data-action="toggle-quick-skill" data-actor-id="{{../activeActor.id}}" data-skill-key="{{skill.quickSkillKey}}">Pin</button><button data-action="unpin-quick-skill" data-actor-id="{{../activeActor.id}}" data-skill-key="{{skill.quickSkillKey}}">Unpin</button></div></div>{{/each}}{{/if}}
{{#if isSpellsDrawerOpen}}<input class="qd30-search" type="search" value="{{spellsSearch}}" data-action="spells-search" placeholder="Search spells" />{{#each indexedSpells as |spell|}}<div class="qd30-action-row" data-search-row="spells" data-search-text="{{spell.searchText}}"><div><strong>{{spell.name}}</strong></div><div><button data-action="toggle-favorite-spell" data-actor-id="{{../activeActor.id}}" data-spell-key="{{spell.spellKey}}">★</button><button data-action="roll-spell" data-actor-id="{{../activeActor.id}}" data-spell-index="{{spell.index}}">Roll</button></div></div>{{/each}}{{/if}}
<button data-action="open-reference" data-ref-type="book" data-ref-name="Basic" data-ref-page="1" data-ref-source="manual">Ref</button>
<button data-action="open-reference-index">Index</button>
</section>
