<section class="quickdeck-art-prototype" aria-label="Static QuickDeck art prototype">
  <header class="quickdeck-art-prototype__notice">
    <span>Static Art Prototype</span>
    <strong>GURPS QuickDeck Command Desk</strong>
    <em>Sample data only · no live actions wired</em>
  </header>

  <div class="quickdeck-art-prototype__stage">
    <button type="button" class="quickdeck-art-prototype__collapse-handle quickdeck-art-prototype__collapse-handle--left" disabled aria-label="Prototype left roster collapse handle"></button>
    <button type="button" class="quickdeck-art-prototype__collapse-handle quickdeck-art-prototype__collapse-handle--right" disabled aria-label="Prototype right drawer collapse handle"></button>

    <aside class="quickdeck-art-prototype__panel quickdeck-art-prototype__roster" aria-label="Prototype roster panel">
      <div class="quickdeck-art-prototype__scroll">
        <header class="quickdeck-art-prototype__panel-header">
          <span>Roster</span>
          <h2>QuickDeck Roster</h2>
          <p>Selected combatants and table-ready resources.</p>
        </header>

        <div class="quickdeck-art-prototype__actor-list" aria-label="Static roster sample actors">
          <article class="quickdeck-art-prototype__actor-card is-active">
            <div class="quickdeck-art-prototype__thumb" aria-hidden="true">AL</div>
            <div class="quickdeck-art-prototype__actor-copy">
              <strong>Alaric Grey</strong>
              <span>Swashbuckler · active</span>
              <div class="quickdeck-art-prototype__mini-resources">
                <span><b>HP</b> 14/14</span>
                <span><b>FP</b> 12/14</span>
              </div>
            </div>
          </article>

          <article class="quickdeck-art-prototype__actor-card">
            <div class="quickdeck-art-prototype__thumb" aria-hidden="true">MI</div>
            <div class="quickdeck-art-prototype__actor-copy">
              <strong>Mira Vale</strong>
              <span>Scout</span>
              <div class="quickdeck-art-prototype__mini-resources">
                <span><b>HP</b> 11/11</span>
                <span><b>FP</b> 10/12</span>
              </div>
            </div>
          </article>

          <article class="quickdeck-art-prototype__actor-card">
            <div class="quickdeck-art-prototype__thumb" aria-hidden="true">TH</div>
            <div class="quickdeck-art-prototype__actor-copy">
              <strong>Thorne Black</strong>
              <span>Knight</span>
              <div class="quickdeck-art-prototype__mini-resources">
                <span><b>HP</b> 18/18</span>
                <span><b>FP</b> 11/11</span>
              </div>
            </div>
          </article>
        </div>

        <section class="quickdeck-art-prototype__available" aria-label="Prototype available actors area">
          <h3>Available Actors</h3>
          <p>Drag/drop and add behavior will be migrated later.</p>
          <div class="quickdeck-art-prototype__available-row"><span>Brother Cadwyn</span><button type="button" disabled>Add</button></div>
          <div class="quickdeck-art-prototype__available-row"><span>Veyra Nine-Lives</span><button type="button" disabled>Add</button></div>
          <div class="quickdeck-art-prototype__available-row"><span>Old Kestrel</span><button type="button" disabled>Add</button></div>
        </section>
      </div>
    </aside>

    <main class="quickdeck-art-prototype__cockpit" aria-label="Prototype center command cockpit">
      <div class="quickdeck-art-prototype__scroll quickdeck-art-prototype__scroll--center">
        <header class="quickdeck-art-prototype__command-title">
          <span>GURPS QuickDeck</span>
          <h1>Command Desk</h1>
        </header>

        <section class="quickdeck-art-prototype__actor-banner" aria-label="Prototype selected actor banner">
          <div class="quickdeck-art-prototype__portrait-frame"><span>AL</span></div>
          <div>
            <span>Selected Actor</span>
            <h2>Alaric Grey</h2>
            <p>Art-first cockpit structure for final review.</p>
          </div>
        </section>

        <section class="quickdeck-art-prototype__resource-grid" aria-label="Prototype resources">
          <article class="quickdeck-art-prototype__resource-card quickdeck-art-prototype__resource-card--hp">
            <span>HP</span>
            <div><button type="button" disabled>-</button><strong>14 / 14</strong><button type="button" disabled>+</button></div>
          </article>
          <article class="quickdeck-art-prototype__resource-card quickdeck-art-prototype__resource-card--fp">
            <span>FP</span>
            <div><button type="button" disabled>-</button><strong>14 / 14</strong><button type="button" disabled>+</button></div>
          </article>
          <article class="quickdeck-art-prototype__resource-card quickdeck-art-prototype__resource-card--move">
            <span>Move</span>
            <strong>6</strong>
          </article>
        </section>

        <section class="quickdeck-art-prototype__defenses" aria-label="Prototype defenses">
          <article class="quickdeck-art-prototype__defense quickdeck-art-prototype__defense--dodge"><span>Dodge</span><strong>10</strong></article>
          <article class="quickdeck-art-prototype__defense quickdeck-art-prototype__defense--parry"><span>Parry</span><strong>13</strong></article>
          <article class="quickdeck-art-prototype__defense quickdeck-art-prototype__defense--block"><span>Block</span><strong>11</strong></article>
        </section>

        <section class="quickdeck-art-prototype__favorites" aria-label="Prototype favorites rows">
          <div class="quickdeck-art-prototype__section-title"><span>Combat Favorites</span></div>
          <div class="quickdeck-art-prototype__favorite-row"><strong>Rapier Thrust</strong><span>16 · 1d+1 imp</span><button type="button" disabled>3d6</button></div>
          <div class="quickdeck-art-prototype__favorite-row"><strong>Main-Gauche Parry</strong><span>14 · defensive</span><button type="button" disabled>3d6</button></div>

          <div class="quickdeck-art-prototype__section-title"><span>Spell Favorites</span></div>
          <div class="quickdeck-art-prototype__spell-row"><strong>Haste</strong><span>15 · Regular</span><button type="button" disabled>Roll</button></div>
          <div class="quickdeck-art-prototype__spell-row"><strong>Blur</strong><span>14 · Regular</span><button type="button" disabled>Roll</button></div>

          <div class="quickdeck-art-prototype__section-title"><span>Quick Skills</span></div>
          <div class="quickdeck-art-prototype__skill-row"><strong>Acrobatics</strong><span>15 · DX/H</span><button type="button" disabled>Roll</button></div>
          <div class="quickdeck-art-prototype__skill-row"><strong>Fast-Draw (Sword)</strong><span>16 · DX/E</span><button type="button" disabled>Roll</button></div>
        </section>
      </div>
      <footer class="quickdeck-art-prototype__footer">GURPS footer rail · chat/hotbar relationship preview</footer>
    </main>

    <aside class="quickdeck-art-prototype__panel quickdeck-art-prototype__drawer" aria-label="Prototype right drawer">
      <div class="quickdeck-art-prototype__tabs" aria-label="Prototype drawer tabs">
        <button type="button" class="is-active" disabled>Combat</button>
        <button type="button" disabled>Skills</button>
        <button type="button" disabled>Quick Skills</button>
        <button type="button" disabled>Spells</button>
        <button type="button" disabled>Settings</button>
      </div>

      <div class="quickdeck-art-prototype__scroll">
        <header class="quickdeck-art-prototype__panel-header">
          <span>Drawer</span>
          <h2>Combat</h2>
          <p>Static sample cards; no Target, Mods, or Attack behavior is wired.</p>
        </header>

        <article class="quickdeck-art-prototype__combat-card">
          <div class="quickdeck-art-prototype__combat-main"><strong>Rapier Thrust</strong><span>Level 16 · 1d+1 imp</span></div>
          <div class="quickdeck-art-prototype__combat-buttons">
            <button type="button" class="quickdeck-art-prototype__square quickdeck-art-prototype__square--target" disabled>Target</button>
            <button type="button" class="quickdeck-art-prototype__square quickdeck-art-prototype__square--mods" disabled>Mods</button>
            <button type="button" class="quickdeck-art-prototype__square quickdeck-art-prototype__square--attack" disabled><i aria-hidden="true"></i><span>Attack</span></button>
            <button type="button" class="quickdeck-art-prototype__square quickdeck-art-prototype__square--favorite" disabled>★</button>
          </div>
        </article>

        <article class="quickdeck-art-prototype__combat-card">
          <div class="quickdeck-art-prototype__combat-main"><strong>Rapier Swing</strong><span>Level 15 · 1d cut</span></div>
          <div class="quickdeck-art-prototype__combat-buttons">
            <button type="button" class="quickdeck-art-prototype__square quickdeck-art-prototype__square--target" disabled>Target</button>
            <button type="button" class="quickdeck-art-prototype__square quickdeck-art-prototype__square--mods" disabled>Mods</button>
            <button type="button" class="quickdeck-art-prototype__square quickdeck-art-prototype__square--attack" disabled><i aria-hidden="true"></i><span>Attack</span></button>
            <button type="button" class="quickdeck-art-prototype__square quickdeck-art-prototype__square--favorite" disabled>★</button>
          </div>
        </article>

        <article class="quickdeck-art-prototype__combat-card">
          <div class="quickdeck-art-prototype__combat-main"><strong>Thrown Knife</strong><span>Level 13 · 1d-2 imp</span></div>
          <div class="quickdeck-art-prototype__combat-buttons">
            <button type="button" class="quickdeck-art-prototype__square quickdeck-art-prototype__square--target" disabled>Target</button>
            <button type="button" class="quickdeck-art-prototype__square quickdeck-art-prototype__square--mods" disabled>Mods</button>
            <button type="button" class="quickdeck-art-prototype__square quickdeck-art-prototype__square--attack" disabled><i aria-hidden="true"></i><span>Attack</span></button>
            <button type="button" class="quickdeck-art-prototype__square quickdeck-art-prototype__square--favorite" disabled>★</button>
          </div>
        </article>

        <section class="quickdeck-art-prototype__drawer-mock" aria-label="Prototype alternate drawer rows">
          <h3>Skill / Spell Row Samples</h3>
          <div class="quickdeck-art-prototype__skill-row"><strong>Stealth</strong><span>14 · DX/A</span><button type="button" disabled>Roll</button></div>
          <div class="quickdeck-art-prototype__spell-row"><strong>Shield</strong><span>15 · Blocking</span><button type="button" disabled>Roll</button></div>
        </section>
      </div>
    </aside>

    <aside class="quickdeck-art-prototype__popout" aria-label="Prototype reference popout preview">
      <button type="button" class="quickdeck-art-prototype__popout-close" disabled aria-label="Prototype close reference popout">×</button>
      <div class="quickdeck-art-prototype__popout-title"><span>Reference Scroll</span><strong>Rapier</strong></div>
      <div class="quickdeck-art-prototype__popout-body">
        <section><h3>Plain Info Panel</h3><p>This preview intentionally uses a clean scroll body with text sections, not per-attack weapon art.</p></section>
        <section><h3>Use Notes</h3><p>Future live migration can place selected skill, spell, or rules reference summaries here.</p></section>
        <section><h3>Related</h3><div class="quickdeck-art-prototype__related-row">Main-Gauche</div><div class="quickdeck-art-prototype__related-row">Feint</div><div class="quickdeck-art-prototype__related-row">Evaluate</div></section>
      </div>
    </aside>
  </div>
</section>
